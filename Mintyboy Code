StockData fetchStock(const String& sym) {
  StockData s; s.valid=false; s.closeCount=0;
  if(WiFi.status()!=WL_CONNECTED)return s;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url="https://query1.finance.yahoo.com/v8/finance/chart/"+sym+"?interval=1d&range=5d";
  http.setTimeout(12000);
  http.begin(client,url);
  http.addHeader("User-Agent","Mozilla/5.0");
  http.addHeader("Accept","application/json");
  int code=http.GET();
  if(code==200){
    String body=http.getString();
    // Parse regularMarketPrice
    int pi=body.indexOf("\"regularMarketPrice\":");
    if(pi>=0){pi+=21;int pe=body.indexOf(",",pi);if(pe>pi)s.price=body.substring(pi,pe);}
    // Parse previousClose
    int pci=body.indexOf("\"previousClose\":");
    float prevClose=0;
    if(pci>=0){pci+=16;int pce=body.indexOf(",",pci);if(pce>pci)prevClose=body.substring(pci,pce).toFloat();}
    // Parse currency
    int ci=body.indexOf("\"currency\":\"");
    if(ci>=0){ci+=12;int ce=body.indexOf("\"",ci);if(ce>ci)s.currency=body.substring(ci,ce);}
    // Parse shortName
    int ni=body.indexOf("\"shortName\":\"");
    if(ni>=0){ni+=13;int ne=body.indexOf("\"",ni);if(ne>ni)s.name=body.substring(ni,min(ne,(int)(ni+20)));}
    // Parse close array
    int closeIdx=body.indexOf("\"close\":[");
    if(closeIdx>=0){
      closeIdx+=9;int closeEnd=body.indexOf("]",closeIdx);
      String arr=body.substring(closeIdx,closeEnd);
      int start=0;
      while(s.closeCount<5){
        int comma=arr.indexOf(",",start);
        String tok=(comma>=0)?arr.substring(start,comma):arr.substring(start);
        tok.trim();if(tok.length()==0)break;
        s.closes[s.closeCount++]=tok.toFloat();
        if(comma<0)break;start=comma+1;
      }
    }
    // Compute change
    float curPrice=s.price.toFloat();
    if(prevClose>0){float ch=curPrice-prevClose;float pct=ch/prevClose*100;char buf[16];sprintf(buf,"%+.2f",ch);s.change=String(buf);sprintf(buf,"%+.2f%%",pct);s.changePct=String(buf);}
    s.symbol=sym.substring(0);s.symbol.toUpperCase();
    s.valid=(s.price.length()>0);
  }
  http.end();return s;
}

void drawStockChart(float* closes,int count,int x,int y,int w,int h,uint16_t col){
  if(count<2)return;
  float mn=closes[0],mx=closes[0];
  for(int i=1;i<count;i++){mn=min(mn,closes[i]);mx=max(mx,closes[i]);}
  float range=mx-mn; if(range<0.001f)range=1;
  tft.drawRect(x,y,w,h,COL_DIM);
  float step=(float)(w-2)/(count-1);
  int prevPx=-1,prevPy=-1;
  for(int i=0;i<count;i++){
    int px=x+1+(int)(i*step);
    int py=y+h-1-(int)((closes[i]-mn)/range*(h-2));
    tft.fillCircle(px,py,2,col);
    if(prevPx>=0){tft.drawLine(prevPx,prevPy,px,py,col);}
    prevPx=px;prevPy=py;
  }
  // Labels
  tft.setTextColor(COL_DIM);tft.setTextSize(1);
  tft.setCursor(x,y+h+2);char lb[8];sprintf(lb,"%.1f",mn);tft.print(lb);
  sprintf(lb,"%.1f",mx);tft.setCursor(x+w-(int)strlen(lb)*6,y-8);tft.print(lb);
}

