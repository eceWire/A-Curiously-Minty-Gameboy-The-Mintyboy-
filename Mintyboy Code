// URL-encode a string for HTTP POST body
String urlEncode(const String& s) {
  String out = "";
  for (int i = 0; i < (int)s.length(); i++) {
    char c = s[i];
    if (isAlphaNumeric(c) || c=='-' || c=='_' || c=='.' || c=='~') {
      out += c;
    } else {
      char buf[4];
      sprintf(buf, "%%%02X", (uint8_t)c);
      out += buf;
    }
  }
  return out;
}

// Base64 encode (for Basic Auth header)
String base64Encode(const String& s) {
  const char* b64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
  String out = "";
  int len = s.length();
  for (int i = 0; i < len; i += 3) {
    uint8_t a = (uint8_t)s[i];
    uint8_t b = (i+1 < len) ? (uint8_t)s[i+1] : 0;
    uint8_t c = (i+2 < len) ? (uint8_t)s[i+2] : 0;
    out += b64[a >> 2];
    out += b64[((a & 3) << 4) | (b >> 4)];
    out += (i+1 < len) ? b64[((b & 0xF) << 2) | (c >> 6)] : '=';
    out += (i+2 < len) ? b64[c & 0x3F]                     : '=';
  }
  return out;
}

