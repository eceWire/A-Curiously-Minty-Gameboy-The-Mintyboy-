String urlEncode(const String& s){
  String out=""; for(int i=0;i<(int)s.length();i++){char c=s[i];if(isAlphaNumeric(c)||c=='-'||c=='_'||c=='.'||c=='~')out+=c;else{char buf[4];sprintf(buf,"%%%02X",(uint8_t)c);out+=buf;}}return out;
}
String base64Encode(const String& s){
  const char* b64="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
  String out="";int len=s.length();
  for(int i=0;i<len;i+=3){uint8_t a=(uint8_t)s[i],b=(i+1<len)?(uint8_t)s[i+1]:0,c=(i+2<len)?(uint8_t)s[i+2]:0;out+=b64[a>>2];out+=b64[((a&3)<<4)|(b>>4)];out+=(i+1<len)?b64[((b&0xF)<<2)|(c>>6)]:'=';out+=(i+2<len)?b64[c&0x3F]:'=';}
  return out;
}
void smsStatusBanner(const String& msg,uint16_t color){tft.fillRect(0,218,240,22,color);tft.setTextColor(ST77XX_WHITE);tft.setTextSize(1);tft.setCursor(4,225);String m=msg;if(m.length()>38)m=m.substring(0,38);tft.print(m);}
String twilioSend(const String& toNum,const String& body){
  if(WiFi.status()!=WL_CONNECTED)return "No WiFi";
  if(!twSID[0]||!twToken[0]||!twFrom[0])return "No credentials";
  WiFiClientSecure client;client.setInsecure();
  HTTPClient http;
  String url="https://api.twilio.com/2010-04-01/Accounts/";url+=twSID;url+="/Messages.json";
  String authStr=String(twSID)+":"+String(twToken);
  String auth="Basic "+base64Encode(authStr);
  String postBody="To="+urlEncode(toNum)+"&From="+urlEncode(String(twFrom))+"&Body="+urlEncode(body);
  http.setTimeout(15000);http.begin(client,url);
  http.addHeader("Authorization",auth);http.addHeader("Content-Type","application/x-www-form-urlencoded");
  int code=http.POST(postBody);String result="";
  if(code!=201){String resp=http.getString();int mi=resp.indexOf("\"message\":\"");if(mi>=0){mi+=11;int me=resp.indexOf("\"",mi);result=(me>mi)?resp.substring(mi,me):"Error "+String(code);}else result="HTTP "+String(code);}
  http.end();return result;
}
int twilioFetchInbox(SmsMsg* msgs,int maxCount){
  if(WiFi.status()!=WL_CONNECTED||!twSID[0]||!twToken[0]||!twFrom[0])return 0;
  WiFiClientSecure client;client.setInsecure();
  HTTPClient http;
  String url="https://api.twilio.com/2010-04-01/Accounts/";url+=twSID;url+="/Messages.json?To=";url+=urlEncode(String(twFrom));url+="&PageSize=";url+=String(maxCount);
  String auth="Basic "+base64Encode(String(twSID)+":"+String(twToken));
  http.setTimeout(15000);http.begin(client,url);http.addHeader("Authorization",auth);
  int code=http.GET();if(code!=200){http.end();return 0;}
  String json=http.getString();http.end();
  int count=0,pos=0;
  while(count<maxCount){
    int fi=json.indexOf("\"from\":",pos);if(fi<0)break;fi+=7;while(fi<(int)json.length()&&(json[fi]==' '||json[fi]=='"'))fi++;int fe=json.indexOf("\"",fi);if(fe<0)break;String from=json.substring(fi,fe);
    int bi=json.indexOf("\"body\":",fe);if(bi<0)break;bi+=7;while(bi<(int)json.length()&&(json[bi]==' '||json[bi]=='"'))bi++;int be=bi;while(be<(int)json.length()){if(json[be]=='\\'){be+=2;continue;}if(json[be]=='"')break;be++;}String body=json.substring(bi,be);
    if(from.length()>12)from="..."+from.substring(from.length()-7);if(body.length()>30)body=body.substring(0,29)+"~";
    msgs[count].from=from;msgs[count].body=body;msgs[count].date="";count++;pos=be+1;
  }
  return count;
}
