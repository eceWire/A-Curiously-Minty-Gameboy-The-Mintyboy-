void redrawCurrentTab(bool storageErased) {
  switch (settingsTab) {
    case 0: drawStorageTab(storageErased); break;
    case 1: drawWifiTab();                 break;
    case 2: drawBLETab();                  break;
    case 3: drawThemeTab();                break;
    case 4: drawSmsTab();                  break;
  }
}

void runSettings() {
  settingsTab = 0;
  bool storageErased = false;
  drawStorageTab(false);

  while (true) {
    if (btnPressed(BTN_LEFT))  { settingsTab=(settingsTab+NUM_TABS-1)%NUM_TABS; storageErased=false; redrawCurrentTab(false); }
    if (btnPressed(BTN_RIGHT)) { settingsTab=(settingsTab+1)%NUM_TABS;           storageErased=false; redrawCurrentTab(false); }

    if (settingsTab == 0 && btnPressed(BTN_DOWN) && !storageErased) {
      tft.fillRoundRect(8, 192, 224, 20, 3, 0x8000);
      tft.setTextColor(ST77XX_WHITE); tft.setTextSize(1);
      tft.setCursor(14, 199); tft.print("Hold DOWN 2 s to confirm erase...");
      unsigned long t0 = millis(); bool confirmed = false;
      while (digitalRead(BTN_DOWN) == LOW) {
        if (millis()-t0 >= 2000) { confirmed = true; break; }
        delay(10);
      }
      if (confirmed) { ee_eraseAll(); storageErased = true; }
      drawStorageTab(storageErased);
    }

    if (settingsTab == 1) {
      if (btnPressed(BTN_DOWN)) { runWifiSettings(); drawWifiTab(); }
      if (btnPressed(BTN_UP) && WiFi.status()==WL_CONNECTED) { WiFi.disconnect(true); delay(400); drawWifiTab(); }
    }

    if (settingsTab == 2 && btnPressed(BTN_DOWN)) {
      if (bleAdvertising) bleStop(); else bleStart();
      EEPROM.write(EE_BLE_ADDR, bleAdvertising ? 1 : 0);
      EEPROM.commit();
      drawBLETab();
    }

    if (settingsTab == 3 && btnPressed(BTN_DOWN)) {
      darkTheme = !darkTheme;
      EEPROM.write(EE_THEME_ADDR, darkTheme ? 0 : 1);
      EEPROM.commit();
      applyTheme();
      drawThemeTab();
    }

    if (settingsTab == 4) {
      // UP = edit SID
      if (btnPressed(BTN_UP)) {
        String s = textEntry("Twilio Account SID (AC...):", twSID);
        s.toCharArray(twSID, 36);
        ee_writeMagic(); ee_writeStr(EE_TW_SID_ADDR, twSID, 36);
        drawSmsTab();
      }
      // DOWN = edit Auth Token
      if (btnPressed(BTN_DOWN)) {
        String s = textEntry("Twilio Auth Token:", twToken);
        s.toCharArray(twToken, 34);
        ee_writeMagic(); ee_writeStr(EE_TW_TOK_ADDR, twToken, 34);
        drawSmsTab();
      }
      // LEFT = edit From number
      if (btnPressed(BTN_LEFT) && settingsTab == 4) {
        String s = textEntry("Twilio 'From' number (+1xxx):", twFrom);
        s.toCharArray(twFrom, 18);
        ee_writeMagic(); ee_writeStr(EE_TW_FROM_ADDR, twFrom, 18);
        drawSmsTab();
        return; // prevent tab switch from eating this press
      }
      // RIGHT = clear all SMS credentials
      if (btnPressed(BTN_RIGHT)) {
        memset(twSID,   0, sizeof(twSID));
        memset(twToken, 0, sizeof(twToken));
        memset(twFrom,  0, sizeof(twFrom));
        memset(twLastTo,0, sizeof(twLastTo));
        ee_writeStr(EE_TW_SID_ADDR,  twSID,    36);
        ee_writeStr(EE_TW_TOK_ADDR,  twToken,  34);
        ee_writeStr(EE_TW_FROM_ADDR, twFrom,   18);
        ee_writeStr(EE_TW_TO_ADDR,   twLastTo, 18);
        drawSmsTab();
        return;
      }
    }

    if (btnPressed(BTN_MODE)) { currentState = STATE_MENU; return; }
    delay(10);
  }
}

