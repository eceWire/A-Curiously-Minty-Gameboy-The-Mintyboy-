void drawMenuClock() {
  struct tm t; if (!getLocalTime(&t,0)) return;
  char timebuf[10]; strftime(timebuf,sizeof(timebuf),"%I:%M %p",&t);
  char datebuf[12]; strftime(datebuf,sizeof(datebuf),"%a %b %d",&t);
  tft.fillRect(152,2,88,14,COL_BG);
  tft.setTextColor(ST77XX_YELLOW); tft.setTextSize(1);
  tft.setCursor(156,6); tft.print(timebuf);
  tft.fillRect(140,34,100,10,COL_BG);
  tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1);
  tft.setCursor(142,34); tft.print(datebuf);
}

void drawMenu() {
  tft.fillScreen(COL_BG);
  tft.setTextSize(2); tft.setTextColor(COL_FG);
  tft.setCursor(36,2); tft.print("GAME SELECT");
  tft.setTextSize(1); tft.setTextColor(COL_ACCENT);
  tft.setCursor(14,22); tft.print("< L/R > browse    DOWN = enter");
  bool wfConn=(WiFi.status()==WL_CONNECTED);
  tft.setTextColor(wfConn?ST77XX_GREEN:COL_DIM);
  tft.setCursor(6,34);
  if (wfConn) { tft.print("WiFi: "); tft.print(WiFi.SSID()); }
  else          tft.print("WiFi: disconnected");
  // 9 compact cards, 20px each, 2px gap, starting at y=44
  for (int i=0;i<NUM_ITEMS;i++) {
    int cX=8,cY=44+i*22,cW=224,cH=20;
    bool sel=(i==menuSel);
    uint16_t bg=sel?menuColors[i]:COL_CARD, fg=sel?ST77XX_BLACK:COL_FG, bdr=sel?ST77XX_WHITE:COL_DIM;
    tft.fillRoundRect(cX,cY,cW,cH,4,bg);
    tft.drawRoundRect(cX,cY,cW,cH,4,bdr);
    tft.setTextSize(1); tft.setTextColor(fg);
    uint8_t ts=(strlen(menuNames[i])<=6)?2:1;
    tft.setTextSize(ts);
    int tx=cX+(cW-(int)strlen(menuNames[i])*6*ts)/2;
    int ty=cY+(cH-8*ts)/2;
    tft.setCursor(tx,ty); tft.print(menuNames[i]);
  }
}

void runMenu() {
  applyTheme(); drawMenu(); drawMenuClock();
  unsigned long lastClockMs=0;
  while (true) {
    unsigned long nowMs=millis();
    if (nowMs-lastClockMs>=1000) { drawMenuClock(); lastClockMs=nowMs; }
    if (btnPressed(BTN_LEFT))  { menuSel=(menuSel+NUM_ITEMS-1)%NUM_ITEMS; drawMenu(); drawMenuClock(); lastClockMs=millis(); }
    if (btnPressed(BTN_RIGHT)) { menuSel=(menuSel+1)%NUM_ITEMS;           drawMenu(); drawMenuClock(); lastClockMs=millis(); }
    if (btnPressed(BTN_DOWN)||btnPressed(BTN_UP)||btnPressed(BTN_MODE)) break;
    delay(10);
  }
  switch (menuSel) {
    case 0: currentState=STATE_GAMES;     break;
    case 1: currentState=STATE_WEATHER;   break;
    case 2: currentState=STATE_SMS;       break;
    case 3: currentState=STATE_STOPWATCH; break;
    case 4: currentState=STATE_NASA;      break;
    case 5: currentState=STATE_STOCKS;    break;
    case 6: currentState=STATE_NEWS;      break;
    case 7: currentState=STATE_CALC;      break;
    case 8: currentState=STATE_SETTINGS;  break;
  }
}

String enterPassword(const String& ssid) {
  String p="Password for: "+ssid; return textEntry(p.c_str(),"",true);
}

// ======================================================
//  WIFI SCANNER
// ======================================================
void runWifiSettings() {
  int n=0;
  doScan:
  tft.fillScreen(COL_BG); tft.setTextColor(COL_FG); tft.setTextSize(2);
  tft.setCursor(22,26); tft.print("Scanning WiFi");
  tft.setTextSize(1); tft.setTextColor(COL_ACCENT); tft.setCursor(20,58); tft.print("Please wait...");
  WiFi.mode(WIFI_STA); WiFi.disconnect(); delay(1500);
  n=WiFi.scanNetworks(false,true);
  if (n<=0) {
    tft.fillScreen(COL_BG); tft.setTextColor(ST77XX_RED); tft.setTextSize(1);
    tft.setCursor(10,80); tft.print("No networks found.");
    tft.setTextColor(COL_ACCENT); tft.setCursor(10,100); tft.print("Move closer to router");
    tft.setTextColor(ST77XX_YELLOW); tft.setCursor(10,140); tft.print("RIGHT=scan again  MODE=back");
    while (true) { if(btnPressed(BTN_RIGHT))goto doScan; if(btnPressed(BTN_MODE))return; delay(10); }
  }
  int sel=0; const int MAX_SHOW=8;
  auto drawList=[&](){
    tft.fillScreen(COL_BG); tft.setTextColor(COL_FG); tft.setTextSize(1);
    tft.setCursor(4,4); tft.print("WiFi: U/D=scroll  R=connect  MODE=back");
    tft.drawFastHLine(0,14,240,COL_DIM);
    int startIdx=sel-3; if(startIdx<0)startIdx=0;
    int maxStart=n-MAX_SHOW; if(maxStart<0)maxStart=0;
    if(startIdx>maxStart)startIdx=maxStart;
    for (int i=0;i<MAX_SHOW&&(startIdx+i)<n;i++) {
      int idx=startIdx+i; bool isSel=(idx==sel); int ry=18+i*26;
      tft.fillRoundRect(4,ry,232,22,3,isSel?ST77XX_BLUE:COL_CARD);
      tft.setTextColor(isSel?ST77XX_WHITE:COL_FG); tft.setCursor(8,ry+7);
      String ssid=WiFi.SSID(idx); if(ssid.length()>24)ssid=ssid.substring(0,23)+"~";
      tft.print(ssid);
      int rssi=WiFi.RSSI(idx);
      tft.setCursor(190,ry+7); tft.print(rssi>-55?"Ex":rssi>-70?"Ok":"Lo");
    }
  };
  drawList();
  while (true) {
    if(btnPressed(BTN_UP))  {sel=(sel+n-1)%n;drawList();}
    if(btnPressed(BTN_DOWN)){sel=(sel+1)%n;  drawList();}
    if(btnPressed(BTN_RIGHT)){
      String ssid=WiFi.SSID(sel); String password=enterPassword(ssid);
      tft.fillScreen(COL_BG); tft.setTextColor(COL_FG); tft.setTextSize(1);
      tft.setCursor(10,70); tft.print("Connecting to:"); tft.setCursor(10,86); tft.print(ssid);
      WiFi.begin(ssid.c_str(),password.c_str());
      unsigned long t0=millis();
      while(WiFi.status()!=WL_CONNECTED&&millis()-t0<12000)delay(300);
      if(WiFi.status()==WL_CONNECTED){
        strncpy(savedSSID,ssid.c_str(),sizeof(savedSSID));
        strncpy(savedPass,password.c_str(),sizeof(savedPass));
        ee_writeStr(EE_SSID_ADDR,savedSSID,34); ee_writeStr(EE_PASS_ADDR,savedPass,66); ee_writeMagic();
        tft.fillScreen(COL_BG); tft.setTextColor(ST77XX_GREEN); tft.setTextSize(1);
        tft.setCursor(10,80); tft.print("Connected!"); tft.setCursor(10,96); tft.print(WiFi.localIP().toString());
        buzzOK(); delay(2000); return;
      } else {
        tft.fillScreen(COL_BG); tft.setTextColor(ST77XX_RED); tft.setTextSize(1);
        tft.setCursor(10,80); tft.print("Connection failed."); buzzFail(); delay(2500); drawList();
      }
    }
    if(btnPressed(BTN_MODE))return; delay(10);
  }
}

