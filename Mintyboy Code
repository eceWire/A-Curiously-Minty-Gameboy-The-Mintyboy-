// ============================================================
//  Combined Game Console + Weather Station + SMS Messenger
//  Target: Arduino Nano ESP32 (ESP32-S3)
//
//  MENU: 2048 | Tetris | Pong | Weather | SMS | Settings
//
//  SMS via Twilio REST API (WiFi required, no extra hardware):
//    - Send SMS to any number
//    - View Inbox: last 10 received messages polled from Twilio
//    - Twilio credentials entered once in Settings > SMS tab
//    - Credentials stored encrypted-at-rest in EEPROM
//
//  Settings tabs: Storage | WiFi | BLE | Theme | SMS
//
//  MENU navigation:
//    BTN_LEFT / BTN_RIGHT — cycle options
//    BTN_DOWN             — select
//
//  In-game:
//    2048   : LEFT/RIGHT/UP/DOWN slides tiles
//    Tetris : LEFT=left  UP=rotate  RIGHT=right  DOWN=soft drop
//    Pong   : BTN_LEFT=paddle up   BTN_UP=paddle down   (vs CPU)
//    Hold BTN_MODE ~1 sec → return to menu
//
//  Text entry keyboard:
//    UP / DOWN  — cycle through characters
//    RIGHT      — add selected character
//    LEFT       — backspace
//    Hold MODE 1.5 s — confirm / done
//
//  LIBRARIES (install via Arduino Library Manager):
//    Adafruit ST7789   Adafruit GFX
//    WiFi, HTTPClient, BLE, base64 are in the ESP32 Arduino core.
// ============================================================

#include <Adafruit_GFX.h>
