// Returns city name from IP geolocation ("Chicago", "London", etc.)
// Returns "" on failure.
String fetchCityFromIP() {
  if (WiFi.status() != WL_CONNECTED) return "";
  HTTPClient http;
  http.setTimeout(6000);
  http.begin("http://ip-api.com/json/?fields=city");
  http.addHeader("User-Agent", "curl/7.0");
  int code = http.GET();
  String city = "";
  if (code == 200) {
    String body = http.getString();
    // Parse: {"city":"Chicago"}
    int ci = body.indexOf("\"city\":\"");
    if (ci >= 0) {
      ci += 8;
      int ce = body.indexOf("\"", ci);
      if (ce > ci) city = body.substring(ci, ce);
    }
  }
  http.end();
  return city;
}

WeatherData fetchWeather(const String& city) {
  WeatherData w; w.valid = false;
  if (WiFi.status() != WL_CONNECTED) return w;
  HTTPClient http;
  String c = city; c.replace(" ", "+");
  String url = "http://wttr.in/" + c + "?format=%t|%f|%h|%u|%w|%C|%p|%P";
  http.setTimeout(8000);
  http.begin(url);
  http.addHeader("User-Agent", "curl/7.0");
  int code = http.GET();
  if (code == 200) {
    String body = http.getString(); body.trim();
    String parts[8];
    int p = 0, seg = 0;
    for (int i = 0; i <= (int)body.length() && seg < 8; i++) {
      if (i == (int)body.length() || body[i] == '|') {
        parts[seg++] = body.substring(p, i); p = i + 1;
      }
    }
    w.temp=parts[0]; w.feelsLike=parts[1]; w.humidity=parts[2];
    w.uvIndex=parts[3]; w.windSpeed=parts[4];
    w.condition=parts[5]; w.condition.trim();
    if (w.condition.length() > 22) w.condition = w.condition.substring(0,22);
    w.precip=parts[6]; w.precip.trim();
    w.pressure=parts[7]; w.pressure.trim();
    w.valid = (w.temp.length() > 0);
  }
  http.end();
  return w;
}

void runWeather() {
  applyTheme();
  tft.fillScreen(COL_BG);
  tft.setTextColor(COL_FG); tft.setTextSize(2);
  tft.setCursor(30, 6); tft.print("WEATHER");

  if (WiFi.status() != WL_CONNECTED) {
    tft.setTextColor(ST77XX_RED); tft.setTextSize(1);
