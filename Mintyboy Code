// ======================================================
//  BUTTONS  (connect one leg to pin, other leg to GND)
// ======================================================
#define BTN_LEFT   2
#define BTN_UP     3
#define BTN_RIGHT  4
#define BTN_DOWN   5
#define BTN_MODE   6

// ======================================================
//  EEPROM
//  E2END is AVR-only and does NOT exist on ESP32.
//  Hardcode the size and call EEPROM.begin() / commit().
// ======================================================
#define EE_TOTAL      512
#define EE_MAGIC_ADDR  0    // 2 bytes  — save validity check
#define EE_BEST_ADDR   2    // 4 bytes  — 2048 best score
#define EE_SSID_ADDR   6    // 34 bytes — saved WiFi SSID
#define EE_PASS_ADDR   40   // 66 bytes — saved WiFi password
#define EE_THEME_ADDR  106  // 1 byte   — 0=dark  1=light
#define EE_BLE_ADDR    107  // 1 byte   — 0=off   1=advertising
#define EE_CITY_ADDR   108  // 34 bytes — weather city name
// Twilio credentials (142 .. 511)
#define EE_TW_SID_ADDR 142  // 36 bytes — Twilio Account SID (AC...)
#define EE_TW_TOK_ADDR 178  // 34 bytes — Twilio Auth Token
#define EE_TW_FROM_ADDR 212 // 18 bytes — Twilio "From" phone (+1xxxxxxxxxx)
#define EE_TW_TO_ADDR  230  // 18 bytes — last-used "To" phone
#define EE_MAGIC_0     0x20
#define EE_MAGIC_1     0x48

// ======================================================
//  GLOBAL STATE
// ======================================================
