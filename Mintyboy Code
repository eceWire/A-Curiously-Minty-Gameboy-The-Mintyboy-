const char* menuNames[] = {
  "Games","Weather","SMS","Timer","NASA","Stocks","News","Calc","Settings"
};
const uint16_t menuColors[] = {
  0xEAC0, 0x051F, 0xF81F, 0x07E0, 0x051D, 0x04E0, 0xFD20, 0x7BEF, 0xC618
};
const int NUM_ITEMS = 9;
