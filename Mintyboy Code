bool t_tryMove(int dx,int dy,int rot){for(int i=0;i<4;i++)for(int j=0;j<4;j++)if(pgm_read_byte(&tPieces[tPieceType][rot][i][j])){int nx=tPieceX+j+dx,ny=tPieceY+i+dy;if(nx<0||nx>=T_COLS||ny>=T_ROWS)return false;if(ny>=0&&tBoard[ny][nx])return false;}return true;}
