String fetchCityFromIP() {
  if(WiFi.status()!=WL_CONNECTED)return "";
  HTTPClient http; http.setTimeout(6000);
  http.begin("http://ip-api.com/json/?fields=city");
  http.addHeader("User-Agent","curl/7.0");
  int code=http.GET(); String city="";
  if(code==200){
    String body=http.getString();
    int ci=body.indexOf("\"city\":\""); if(ci>=0){ci+=8;int ce=body.indexOf("\"",ci);if(ce>ci)city=body.substring(ci,ce);}
  }
  http.end(); return city;
}

WeatherData fetchWeather(const String& city) {
  WeatherData w; w.valid=false; if(WiFi.status()!=WL_CONNECTED)return w;
  HTTPClient http; String c=city; c.replace(" ","+");
  String url="http://wttr.in/"+c+"?format=%t|%f|%h|%u|%w|%C|%p|%P";
  http.setTimeout(8000); http.begin(url); http.addHeader("User-Agent","curl/7.0");
  int code=http.GET();
  if(code==200){
    String body=http.getString(); body.trim();
    String parts[8]; int p=0,seg=0;
    for(int i=0;i<=(int)body.length()&&seg<8;i++){if(i==(int)body.length()||body[i]=='|'){parts[seg++]=body.substring(p,i);p=i+1;}}
    w.temp=parts[0];w.feelsLike=parts[1];w.humidity=parts[2];w.uvIndex=parts[3];w.windSpeed=parts[4];
    w.condition=parts[5];w.condition.trim();if(w.condition.length()>22)w.condition=w.condition.substring(0,22);
    w.precip=parts[6];w.precip.trim();w.pressure=parts[7];w.pressure.trim();
    w.valid=(w.temp.length()>0);
  }
  http.end(); return w;
}

// AQI via Open-Meteo (free, no key) —————————————————
AQIData fetchAQI() {
  AQIData a; a.valid=false;
  if(WiFi.status()!=WL_CONNECTED)return a;
  // Step 1: get lat/lon from IP
  HTTPClient http; http.setTimeout(6000);
  http.begin("http://ip-api.com/json/?fields=lat,lon");
  http.addHeader("User-Agent","curl/7.0");
  int code=http.GET(); float lat=51.5f,lon=-0.1f;
  if(code==200){
    String body=http.getString();
    int li=body.indexOf("\"lat\":"); if(li>=0){li+=6;int le=body.indexOf(",",li);if(le>li)lat=body.substring(li,le).toFloat();}
    int loi=body.indexOf("\"lon\":"); if(loi>=0){loi+=6;int loe=body.indexOf(",",loi);if(loe>loi)lon=body.substring(loi,loe).toFloat();}
  }
  http.end();
  // Step 2: fetch AQI
  char url[180];
  snprintf(url,sizeof(url),"http://air-quality-api.open-meteo.com/v1/air-quality?latitude=%.4f&longitude=%.4f&current=us_aqi,pm10,pm2_5",lat,lon);
  http.setTimeout(8000); http.begin(url);
  code=http.GET();
  if(code==200){
    String body=http.getString();
    int ai=body.indexOf("\"us_aqi\":"); if(ai>=0){ai+=9;int ae=body.indexOf(",",ai);if(ae>ai)a.aqi=body.substring(ai,ae).toInt();}
    int pi=body.indexOf("\"pm10\":"); if(pi>=0){pi+=7;int pe=body.indexOf(",",pi);if(pe>pi)a.pm10_i=body.substring(pi,pe).toFloat();}
    int p2i=body.indexOf("\"pm2_5\":"); if(p2i>=0){p2i+=8;int p2e=body.indexOf(",",p2i);if(p2e>p2i)a.pm25_i=body.substring(p2i,p2e).toFloat();}
    a.lat=lat; a.lon=lon; a.valid=true;
  }
  http.end(); return a;
}

const char* aqiCategory(int aqi){
  if(aqi<=50)  return "Good";
  if(aqi<=100) return "Moderate";
  if(aqi<=150) return "Unhealthy for Groups";
  if(aqi<=200) return "Unhealthy";
  if(aqi<=300) return "Very Unhealthy";
  return "Hazardous";
}
uint16_t aqiColor(int aqi){
  if(aqi<=50)  return ST77XX_GREEN;
  if(aqi<=100) return ST77XX_YELLOW;
  if(aqi<=150) return ST77XX_ORANGE;
  if(aqi<=200) return ST77XX_RED;
  if(aqi<=300) return ST77XX_MAGENTA;
  return 0x8000;
}

