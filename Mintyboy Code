// ======================================================
//  EEPROM HELPERS
// ======================================================
bool ee_valid() {
  return EEPROM.read(EE_MAGIC_ADDR)==EE_MAGIC_0 && EEPROM.read(EE_MAGIC_ADDR+1)==EE_MAGIC_1;
}
void ee_writeMagic() {
  EEPROM.write(EE_MAGIC_ADDR, EE_MAGIC_0); EEPROM.write(EE_MAGIC_ADDR+1, EE_MAGIC_1); EEPROM.commit();
}
void ee_writeStr(int addr, const char* s, int maxLen) {
  for (int i = 0; i < maxLen-1; i++) { EEPROM.write(addr+i,(uint8_t)s[i]); if (!s[i]) break; }
  EEPROM.write(addr+maxLen-1, 0); EEPROM.commit();
}
void ee_readStr(int addr, char* buf, int maxLen) {
  for (int i = 0; i < maxLen; i++) { buf[i]=(char)EEPROM.read(addr+i); if (!buf[i]) break; }
  buf[maxLen-1]=0;
}
void ee_loadAll() {
  if (!ee_valid()) return;
  g_bestScore = (uint32_t)EEPROM.read(EE_BEST_ADDR)
              | (uint32_t)EEPROM.read(EE_BEST_ADDR+1)<<8
              | (uint32_t)EEPROM.read(EE_BEST_ADDR+2)<<16
              | (uint32_t)EEPROM.read(EE_BEST_ADDR+3)<<24;
  ee_readStr(EE_SSID_ADDR,    savedSSID,    34);
  ee_readStr(EE_PASS_ADDR,    savedPass,    66);
  ee_readStr(EE_CITY_ADDR,    weatherCity,  34);
  if (weatherCity[0]==0) strcpy(weatherCity,"London");
  ee_readStr(EE_TW_SID_ADDR,  twSID,        36);
  ee_readStr(EE_TW_TOK_ADDR,  twToken,      34);
  ee_readStr(EE_TW_FROM_ADDR, twFrom,       18);
  ee_readStr(EE_TW_TO_ADDR,   twLastTo,     18);
  ee_readStr(EE_STOCK_ADDR,   lastStockSym, 12);
  if (lastStockSym[0]==0) strcpy(lastStockSym,"AAPL");
  darkTheme      = (EEPROM.read(EE_THEME_ADDR)!=1);
  bleAdvertising = (EEPROM.read(EE_BLE_ADDR)==1);
}
int  ee_countUsed() { int n=0; for(int i=0;i<EE_TOTAL;i++) if(EEPROM.read(i)!=0xFF)n++; return n; }
void ee_eraseAll() {
  for (int i=0;i<EE_TOTAL;i++) EEPROM.write(i,0xFF); EEPROM.commit();
  g_bestScore=0; savedSSID[0]=savedPass[0]=0; darkTheme=true; bleAdvertising=false;
  strcpy(weatherCity,"London"); strcpy(lastStockSym,"AAPL"); applyTheme();
}

// ======================================================
//  DEBOUNCE
// ======================================================
unsigned long _lastDebounce = 0;
const unsigned long DEBOUNCE_MS = 160;

bool btnPressed(int pin) {
  if (digitalRead(pin)==LOW) {
    unsigned long t = millis();
    if (t-_lastDebounce>DEBOUNCE_MS) {
      _lastDebounce=t;
      while (digitalRead(pin)==LOW) delay(5);
      return true;
    }
  }
  return false;
}
bool anyBtnPressed() {
  return digitalRead(BTN_LEFT)==LOW||digitalRead(BTN_UP)==LOW||
         digitalRead(BTN_RIGHT)==LOW||digitalRead(BTN_DOWN)==LOW||
         digitalRead(BTN_MODE)==LOW;
}
void waitAllReleased() { while (anyBtnPressed()) delay(10); }
void waitAnyPress()    { waitAllReleased(); while (!anyBtnPressed()) delay(10); waitAllReleased(); }

// ======================================================
//  GRID KEYBOARD (QWERTY-style)
// ======================================================
const char* KB_NORM[5] = {
  "1234567890","qwertyuiop","asdfghjkl-","zxcvbnm,.!","@#$%&*+=?/"
};
const char* KB_SHFT[5] = {
  "1234567890","QWERTYUIOP","ASDFGHJKL-","ZXCVBNM,.!","@#$%&*+=?/"
};

String textEntry(const char* prompt, const char* initial, bool hideInput=false) {
  const int NUM_ROWS=5,NUM_COLS=10,SPEC_ROW=5,NUM_SPEC=4;
  bool shifted=false; String result=String(initial); int curRow=1,curCol=0;
  const int KB_X=1,KB_Y=30,CW=23,CH=20,GAP=1;
  const int SPEC_Y=KB_Y+NUM_ROWS*(CH+GAP)+3;
  const int SW[4]={79,51,51,57};

  auto drawKB=[&](){
    tft.fillScreen(COL_BG);
    tft.setTextColor(COL_FG); tft.setTextSize(1);
    char pb[38]; strncpy(pb,prompt,37); pb[37]=0;
    tft.setCursor(3,3); tft.print(pb);
    tft.fillRoundRect(2,13,236,15,2,COL_CARD);
    tft.drawRoundRect(2,13,236,15,2,COL_DIM);
    tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1); tft.setCursor(5,18);
    if (hideInput) { int sh=min((int)result.length(),37); for(int i=0;i<sh;i++) tft.print('*'); }
    else { String d=result; if(d.length()>37) d=d.substring(d.length()-37); tft.print(d); }
    tft.setTextColor(ST77XX_WHITE); tft.print('|');
    const char** kb=shifted?KB_SHFT:KB_NORM;
    for (int r=0;r<NUM_ROWS;r++) for (int c=0;c<NUM_COLS;c++) {
      int x=KB_X+c*(CW+GAP),y=KB_Y+r*(CH+GAP); bool sel=(curRow==r&&curCol==c);
      tft.fillRect(x,y,CW,CH,sel?ST77XX_BLUE:COL_CARD);
      if(sel) tft.drawRect(x,y,CW,CH,ST77XX_WHITE);
      tft.setTextColor(sel?ST77XX_WHITE:COL_FG); tft.setTextSize(1);
      tft.setCursor(x+(CW-6)/2,y+(CH-8)/2); tft.print(kb[r][c]);
    }
    const char* spLbl[4]={"SPACE","CAPS","DEL","DONE"};
    uint16_t spBg[4]={COL_CARD,(uint16_t)(shifted?ST77XX_ORANGE:COL_CARD),(uint16_t)0x8000,(uint16_t)0x0410};
    int sx=2;
    for (int i=0;i<NUM_SPEC;i++) {
      bool sel=(curRow==SPEC_ROW&&curCol==i);
      tft.fillRoundRect(sx,SPEC_Y,SW[i]-2,CH,3,sel?ST77XX_BLUE:spBg[i]);
      if(sel) tft.drawRoundRect(sx,SPEC_Y,SW[i]-2,CH,3,ST77XX_WHITE);
      tft.setTextColor(sel?ST77XX_WHITE:(i==3?ST77XX_WHITE:COL_FG)); tft.setTextSize(1);
      int lw=strlen(spLbl[i])*6;
      tft.setCursor(sx+(SW[i]-2-lw)/2,SPEC_Y+(CH-8)/2); tft.print(spLbl[i]); sx+=SW[i];
    }
    tft.setTextColor(COL_DIM); tft.setTextSize(1);
    tft.setCursor(3,230); tft.print("D-pad=navigate  MODE=type  hold=done");
  };

  drawKB();
  while (true) {
    bool moved=false;
    if (btnPressed(BTN_UP))   { if(curRow==SPEC_ROW){curRow=NUM_ROWS-1;if(curCol>=NUM_COLS)curCol=NUM_COLS-1;}else if(curRow>0)curRow--; moved=true; }
    if (btnPressed(BTN_DOWN)) { if(curRow<NUM_ROWS-1)curRow++;else if(curRow==NUM_ROWS-1){curRow=SPEC_ROW;if(curCol>=NUM_SPEC)curCol=0;} moved=true; }
    if (btnPressed(BTN_LEFT)) { int cols=(curRow==SPEC_ROW)?NUM_SPEC:NUM_COLS; curCol=(curCol+cols-1)%cols; moved=true; }
    if (btnPressed(BTN_RIGHT)){ int cols=(curRow==SPEC_ROW)?NUM_SPEC:NUM_COLS; curCol=(curCol+1)%cols;     moved=true; }
    if (moved) drawKB();
    if (digitalRead(BTN_MODE)==LOW) {
      unsigned long t0=millis();
      while (digitalRead(BTN_MODE)==LOW) { if(millis()-t0>1500){waitAllReleased();return result;} delay(10); }
      if (curRow<NUM_ROWS) { const char** kb=shifted?KB_SHFT:KB_NORM; if(result.length()<63)result+=kb[curRow][curCol]; shifted=false; }
      else { switch(curCol){ case 0:if(result.length()<63)result+=' ';break; case 1:shifted=!shifted;break; case 2:if(result.length()>0)result.remove(result.length()-1);break; case 3:return result; } }
      drawKB();
    }
    delay(10);
  }
}

