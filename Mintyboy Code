    tft.setCursor(10, 118); tft.print("DOWN = set city manually");
    tft.setCursor(10, 134); tft.print("MODE = back to menu");

    while (true) {
      if (btnPressed(BTN_DOWN)) {
        String city = textEntry("Enter city name:", weatherCity);
        city.trim();
        if (city.length() > 0) {
          city.toCharArray(weatherCity, 34);
          ee_writeMagic(); ee_writeStr(EE_CITY_ADDR, weatherCity, 34);
        }
        runWeather(); return;
      }
      if (btnPressed(BTN_MODE) || btnPressed(BTN_LEFT)) { currentState = STATE_MENU; return; }
      delay(10);
    }
  }

  // WiFi connected — auto-detect city from IP
  tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1);
  tft.setCursor(10, 28); tft.print("Detecting location...");

  String detectedCity = fetchCityFromIP();
  String activeCity;

  if (detectedCity.length() > 0) {
    // Use auto-detected city; save it
    detectedCity.toCharArray(weatherCity, 34);
    ee_writeMagic(); ee_writeStr(EE_CITY_ADDR, weatherCity, 34);
    activeCity = detectedCity;
    // Show city with GPS indicator
    tft.fillRect(0, 24, 240, 14, COL_BG);
    tft.setTextColor(ST77XX_GREEN); tft.setTextSize(1);
    tft.setCursor(10, 28); tft.print("\xab GPS\xbb "); tft.print(activeCity);
  } else {
    // Fallback to saved city
    activeCity = String(weatherCity);
    tft.fillRect(0, 24, 240, 14, COL_BG);
    tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1);
    tft.setCursor(10, 28); tft.print(activeCity);
  }

  tft.setTextColor(COL_ACCENT); tft.setTextSize(1);
  tft.setCursor(10, 42); tft.print("Fetching weather...");

  WeatherData w = fetchWeather(activeCity);
  tft.fillRect(0, 38, 240, 14, COL_BG);

  if (!w.valid) {
    tft.setTextColor(ST77XX_RED); tft.setCursor(10, 58);
    tft.print("Fetch failed.");
    tft.setTextColor(COL_ACCENT); tft.setCursor(10, 76);
    tft.print("DOWN=retry  UP=type city  MODE=back");
  } else {
    tft.setTextColor(ST77XX_ORANGE); tft.setTextSize(3);
    tft.setCursor(10, 46); tft.print(w.temp);

    tft.setTextColor(COL_FG); tft.setTextSize(1);
    tft.setCursor(10, 82); tft.print(w.condition);

    tft.drawFastHLine(6, 96, 228, COL_DIM);

    struct InfoRow { const char* lbl; String val; uint16_t col; };
    InfoRow rows[] = {
      { "Feels like", w.feelsLike,  ST77XX_CYAN    },
      { "Humidity",   w.humidity,   0x07FF          },
      { "UV Index",   w.uvIndex,    ST77XX_YELLOW  },
      { "Wind",       w.windSpeed,  ST77XX_GREEN   },
      { "Precip",     w.precip,     ST77XX_BLUE    },
      { "Pressure",   w.pressure,   ST77XX_MAGENTA },
    };
    for (int i = 0; i < 6; i++) {
      int cx = (i%2)*120 + 6, cy = 100 + (i/2)*33;
      tft.fillRoundRect(cx, cy, 116, 29, 4, COL_CARD);
      tft.setTextColor(COL_ACCENT); tft.setTextSize(1);
      tft.setCursor(cx+5, cy+4); tft.print(rows[i].lbl);
      tft.setTextColor(rows[i].col);
      tft.setCursor(cx+5, cy+16); tft.print(rows[i].val);
    }
    tft.setTextColor(COL_DIM); tft.setTextSize(1);
    tft.setCursor(6, 202); tft.print("DOWN=refresh  UP=city  MODE=back");
  }

  while (true) {
    if (btnPressed(BTN_DOWN)) { runWeather(); return; }
    if (btnPressed(BTN_UP)) {
      String city = textEntry("Enter city name:", weatherCity);
      city.trim();
      if (city.length() > 0) {
        city.toCharArray(weatherCity, 34);
        ee_writeMagic(); ee_writeStr(EE_CITY_ADDR, weatherCity, 34);
      }
      runWeather(); return;
    }
    if (btnPressed(BTN_MODE) || btnPressed(BTN_LEFT)) { currentState = STATE_MENU; return; }
    delay(10);
  }
}

