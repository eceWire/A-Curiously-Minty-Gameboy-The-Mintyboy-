  pinMode(BTN_RIGHT,INPUT_PULLUP); pinMode(BTN_DOWN,INPUT_PULLUP);
  pinMode(BTN_MODE, INPUT_PULLUP);
#ifdef BUZZER_PIN
  pinMode(BUZZER_PIN,OUTPUT);
#endif

  EEPROM.begin(EE_TOTAL);
  tft.init(SCREEN_WIDTH,SCREEN_HEIGHT);
  tft.setRotation(2);
  ee_loadAll();applyTheme();
  tft.fillScreen(COL_BG);randomSeed(analogRead(A0));

  // Splash screen
  tft.setTextColor(ST77XX_GREEN);tft.setTextSize(2);tft.setCursor(14,80);tft.print("MINTYBOY");
  tft.setTextColor(ST77XX_YELLOW);tft.setTextSize(1);tft.setCursor(60,100);tft.print("Extended Edition");
  tft.setTextColor(COL_DIM);tft.setCursor(20,120);tft.print("8 games  Stocks  News  NASA  AQI");
#ifdef BUZZER_PIN
  buzz(880,50);delay(80);buzz(1047,80);
#endif

  if(bleAdvertising)bleStart();

  if(savedSSID[0]!=0){
    tft.setTextColor(COL_ACCENT);tft.setTextSize(1);tft.setCursor(10,150);tft.print("Connecting: ");tft.print(savedSSID);
    WiFi.begin(savedSSID,savedPass);unsigned long t0=millis();
    while(WiFi.status()!=WL_CONNECTED&&millis()-t0<8000)delay(200);
    tft.fillRect(0,146,240,14,COL_BG);
    if(WiFi.status()==WL_CONNECTED){
      tft.setTextColor(ST77XX_GREEN);tft.setCursor(10,150);tft.print("WiFi OK  ");tft.print(WiFi.localIP().toString());
      // NTP sync (US Central Time — change TZ string as needed)
      configTzTime("CST6CDT,M3.2.0,M11.1.0","pool.ntp.org","time.cloudflare.com");
    } else {
      tft.setTextColor(ST77XX_RED);tft.setCursor(10,150);tft.print("WiFi failed");
    }
  }
  delay(1200);
  tft.fillScreen(COL_BG);
  currentState=STATE_MENU;
}

void loop(){
  switch(currentState){
    case STATE_MENU:        runMenu();       break;
    case STATE_GAMES:       runGames();      break;
    case STATE_2048:        run2048();       currentState=STATE_GAMES; break;
    case STATE_TETRIS:      runTetris();     currentState=STATE_GAMES; break;
    case STATE_PONG:        runPong();       currentState=STATE_GAMES; break;
    case STATE_FLAPPY:      runFlappy();     break;
    case STATE_SNAKE:       runSnake();      break;
    case STATE_BREAKOUT:    runBreakout();   break;
    case STATE_MINESWEEPER: runMinesweeper();break;
    case STATE_SIMON:       runSimon();      break;
    case STATE_WEATHER:     runWeather();    break;
    case STATE_SMS:         runSMS();        break;
    case STATE_STOPWATCH:   runStopwatch();  break;
    case STATE_NASA:        runNASA();       break;
    case STATE_STOCKS:      runStocks();     break;
    case STATE_NEWS:        runNews();       break;
    case STATE_CALC:        runCalc();       break;
    case STATE_SETTINGS:    runSettings();   break;
    default:                currentState=STATE_MENU; break;
  }
}


