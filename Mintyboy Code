void g_saveBest() {
  if (!ee_valid()) ee_writeMagic();
  EEPROM.write(EE_BEST_ADDR,   (g_bestScore)       & 0xFF);
  EEPROM.write(EE_BEST_ADDR+1, (g_bestScore >>  8) & 0xFF);
  EEPROM.write(EE_BEST_ADDR+2, (g_bestScore >> 16) & 0xFF);
  EEPROM.write(EE_BEST_ADDR+3, (g_bestScore >> 24) & 0xFF);
  EEPROM.commit();
}

void g_getTileRect(int gx, int gy, int &px, int &py, int &sz) {
  const int margin=5, gridTop=SCORE_BAR_H+margin;
  const int gridW=SCREEN_WIDTH-margin*2, gridH=SCREEN_HEIGHT-gridTop-margin;
  sz = (gridW-(GRID-1)*margin)/GRID;
  int totalW=sz*GRID+(GRID-1)*margin, totalH=sz*GRID+(GRID-1)*margin;
  int offsetX=(SCREEN_WIDTH-totalW)/2, offsetY=gridTop+(gridH-totalH)/2;
  px=offsetX+gx*(sz+margin); py=offsetY+gy*(sz+margin);
}

int g_styleIdx(uint32_t val) {
  if (!val) return 0;
  int idx=0; uint32_t t=val;
  while (t>1){t>>=1;idx++;}
  int mx=(int)(sizeof(tileStyles)/sizeof(tileStyles[0]))-1;
  return idx>mx?mx:idx;
}

void g_drawTile(int gx, int gy) {
  int px,py,sz; g_getTileRect(gx,gy,px,py,sz);
  uint32_t val=g_board[gy][gx]; int si=g_styleIdx(val);
  if (!val) { tft.fillRoundRect(px,py,sz,sz,4,0x9CF3); return; }
  tft.fillRoundRect(px,py,sz,sz,4,tileStyles[si].bg);
  String s=String(val); int len=s.length();
  uint8_t ts=(len<=2)?3:(len==3)?2:1;
  int tx=px+(sz-6*ts*len)/2, ty=py+(sz-8*ts)/2;
  if (tx<px+2) tx=px+2;
  tft.setTextSize(ts); tft.setTextColor(tileStyles[si].fg);
  tft.setCursor(tx,ty); tft.print(s);
}

void g_drawChangedTiles() {
  for (int y=0;y<GRID;y++) for (int x=0;x<GRID;x++)
    if (g_board[y][x]!=g_prevBoard[y][x]) { g_drawTile(x,y); g_prevBoard[y][x]=g_board[y][x]; }
}

void g_drawScore() {
  if (g_score==g_lastScore) return;
  g_lastScore=g_score;
  if (g_score>g_bestScore) { g_bestScore=g_score; g_saveBest(); }
  tft.fillRect(0,0,SCREEN_WIDTH,SCORE_BAR_H,ST77XX_BLACK);
  tft.setTextSize(1); tft.setTextColor(ST77XX_WHITE);
  tft.setCursor(4,6); tft.print("SCORE:"); tft.print(g_score);
  String bs="BEST:"; bs+=g_bestScore;
  tft.setCursor(SCREEN_WIDTH-(int)bs.length()*6-4,6); tft.print(bs);
}

void g_redrawAll() {
  tft.fillScreen(GRID_BG);
  for (int y=0;y<GRID;y++) for (int x=0;x<GRID;x++) {
    g_prevBoard[y][x]=0xFFFFFFFF; g_drawTile(x,y); g_prevBoard[y][x]=g_board[y][x];
  }
  g_lastScore=0xFFFFFFFF; g_drawScore();
}

bool g_addRandomTile() {
  int cnt=0, ey[GRID*GRID], ex[GRID*GRID];
  for (int y=0;y<GRID;y++) for (int x=0;x<GRID;x++)
    if (!g_board[y][x]) { ey[cnt]=y; ex[cnt]=x; cnt++; }
  if (!cnt) return false;
  int idx=random(cnt);
  g_board[ey[idx]][ex[idx]]=(random(100)<90)?2:4;
  return true;
}

void g_initGame() {
  g_score=0; g_wonAlready=false; g_lastScore=0xFFFFFFFF;
  for (int y=0;y<GRID;y++) for (int x=0;x<GRID;x++) { g_board[y][x]=0; g_prevBoard[y][x]=0xFFFFFFFF; }
  g_addRandomTile(); g_addRandomTile();
}

void g_showOverlay(const char* msg, uint16_t color) {
  int ow=200,oh=50,ox=(SCREEN_WIDTH-ow)/2,oy=(SCREEN_HEIGHT-oh)/2;
  tft.fillRoundRect(ox,oy,ow,oh,8,ST77XX_BLACK);
  tft.drawRoundRect(ox,oy,ow,oh,8,color);
  tft.setTextColor(color); tft.setTextSize(2);
  tft.setCursor(ox+(ow-(int)strlen(msg)*12)/2,oy+(oh-16)/2);
  tft.print(msg);
}

bool g_slideRow(uint32_t row[]) {
  bool moved=false;
  uint32_t tmp[GRID]={0}; int ti=0;
  for (int i=0;i<GRID;i++) if (row[i]) tmp[ti++]=row[i];
  for (int i=0;i<GRID-1;i++)
    if (tmp[i]&&tmp[i]==tmp[i+1]) { tmp[i]*=2; g_score+=tmp[i]; tmp[++i]=0; }
  uint32_t cmp[GRID]={0}; int ci2=0;
  for (int i=0;i<GRID;i++) if (tmp[i]) cmp[ci2++]=tmp[i];
  for (int i=0;i<GRID;i++) { if (row[i]!=cmp[i]) { moved=true; row[i]=cmp[i]; } }
  return moved;
}

bool g_moveLeft()  { bool m=false; for(int y=0;y<GRID;y++){uint32_t r[GRID];for(int x=0;x<GRID;x++) r[x]=g_board[y][x];       if(g_slideRow(r)){m=true;for(int x=0;x<GRID;x++) g_board[y][x]=r[x];}}      return m; }
bool g_moveRight() { bool m=false; for(int y=0;y<GRID;y++){uint32_t r[GRID];for(int x=0;x<GRID;x++) r[x]=g_board[y][GRID-1-x]; if(g_slideRow(r)){m=true;for(int x=0;x<GRID;x++) g_board[y][GRID-1-x]=r[x];}} return m; }
bool g_moveUp()    { bool m=false; for(int x=0;x<GRID;x++){uint32_t c[GRID];for(int y=0;y<GRID;y++) c[y]=g_board[y][x];       if(g_slideRow(c)){m=true;for(int y=0;y<GRID;y++) g_board[y][x]=c[y];}}      return m; }
bool g_moveDown()  { bool m=false; for(int x=0;x<GRID;x++){uint32_t c[GRID];for(int y=0;y<GRID;y++) c[y]=g_board[GRID-1-y][x]; if(g_slideRow(c)){m=true;for(int y=0;y<GRID;y++) g_board[GRID-1-y][x]=c[y];}} return m; }

bool g_isOver() {
  for (int y=0;y<GRID;y++) for (int x=0;x<GRID;x++) if (!g_board[y][x]) return false;
  for (int y=0;y<GRID;y++) for (int x=0;x<GRID-1;x++) if (g_board[y][x]==g_board[y][x+1]) return false;
  for (int x=0;x<GRID;x++) for (int y=0;y<GRID-1;y++) if (g_board[y][x]==g_board[y+1][x]) return false;
  return true;
}

bool run2048() {
  g_initGame(); g_redrawAll();
  while (true) {
    bool moved=false;
    if      (btnPressed(BTN_UP))    moved=g_moveUp();
    else if (btnPressed(BTN_DOWN))  moved=g_moveDown();
    else if (btnPressed(BTN_LEFT))  moved=g_moveLeft();
    else if (btnPressed(BTN_RIGHT)) moved=g_moveRight();
    else if (digitalRead(BTN_MODE)==LOW) {
      delay(900); if (digitalRead(BTN_MODE)==LOW) { waitAllReleased(); return true; }
    }
    if (moved) {
      g_addRandomTile(); g_drawChangedTiles(); g_drawScore();
      if (!g_wonAlready) for(int y=0;y<GRID;y++) for(int x=0;x<GRID;x++)
        if (g_board[y][x]==2048) { g_wonAlready=true; g_showOverlay("You Win!",ST77XX_GREEN); }
      if (g_isOver()) { g_showOverlay("Game Over",ST77XX_RED); waitAnyPress(); g_initGame(); g_redrawAll(); }
    }
    delay(10);
  }
}

