// Send an SMS via Twilio REST API
// Returns: "" on success, error string on failure
String twilioSend(const String& toNum, const String& body) {
  if (WiFi.status() != WL_CONNECTED)  return "No WiFi";
  if (!twSID[0] || !twToken[0] || !twFrom[0]) return "No credentials";

  HTTPClient http;
  String url = "https://api.twilio.com/2010-04-01/Accounts/";
  url += twSID;
  url += "/Messages.json";

  String authStr = String(twSID) + ":" + String(twToken);
  String auth = "Basic " + base64Encode(authStr);

  String postBody = "To=" + urlEncode(toNum)
                  + "&From=" + urlEncode(String(twFrom))
                  + "&Body=" + urlEncode(body);

  http.setTimeout(15000);
  http.begin(url);
  http.addHeader("Authorization", auth);
  http.addHeader("Content-Type",  "application/x-www-form-urlencoded");
  int code = http.POST(postBody);

  String result = "";
  if (code == 201) {
    result = "";  // success
  } else {
    String resp = http.getString();
    // Extract "message" from JSON: "message":"....."
    int mi = resp.indexOf("\"message\":\"");
    if (mi >= 0) {
      mi += 11;
      int me = resp.indexOf("\"", mi);
      result = (me > mi) ? resp.substring(mi, me) : "Error " + String(code);
    } else {
      result = "HTTP " + String(code);
    }
  }
  http.end();
  return result;
}

// Fetch last N messages received on the Twilio number
// Returns count (0 on failure)
int twilioFetchInbox(SmsMsg* msgs, int maxCount) {
  if (WiFi.status() != WL_CONNECTED)  return 0;
  if (!twSID[0] || !twToken[0] || !twFrom[0]) return 0;

  HTTPClient http;
  String url = "https://api.twilio.com/2010-04-01/Accounts/";
  url += twSID;
  url += "/Messages.json?To=";
  url += urlEncode(String(twFrom));
  url += "&PageSize=";
  url += String(maxCount);

  String authStr = String(twSID) + ":" + String(twToken);
  String auth = "Basic " + base64Encode(authStr);

  http.setTimeout(15000);
  http.begin(url);
  http.addHeader("Authorization", auth);
  int code = http.GET();
  if (code != 200) { http.end(); return 0; }

  String json = http.getString();
  http.end();

  // Simple extraction — find each "from": "..." and "body": "..." block
  int count = 0;
  int pos = 0;
  while (count < maxCount) {
    int fi = json.indexOf("\"from\":", pos);
    if (fi < 0) break;
    fi += 7;
    // skip whitespace/quotes
    while (fi < (int)json.length() && (json[fi]==' '||json[fi]=='"')) fi++;
    int fe = json.indexOf("\"", fi);
    if (fe < 0) break;
    String from = json.substring(fi, fe);

    int bi = json.indexOf("\"body\":", fe);
    if (bi < 0) break;
    bi += 7;
    while (bi < (int)json.length() && (json[bi]==' '||json[bi]=='"')) bi++;
    int be = bi;
    // Walk to closing quote, skipping escaped chars
    while (be < (int)json.length()) {
      if (json[be] == '\\') { be += 2; continue; }
      if (json[be] == '"')  break;
      be++;
    }
    String body = json.substring(bi, be);

    int di = json.indexOf("\"date_sent\":", fe);
    String date = "";
    if (di >= 0) {
      di += 12;
      while (di < (int)json.length() && (json[di]==' '||json[di]=='"')) di++;
      int de = json.indexOf("\"", di);
      if (de > di) {
        date = json.substring(di, de);
        // Trim to "HH:MM" — Twilio format: "Thu, 12 Jun 2025 14:23:10 +0000"
        // Find first ':'
        int ci = date.indexOf(':');
        if (ci >= 2) date = date.substring(ci-2, ci+3); // HH:MM
      }
    }

    // Shorten from to last 7 digits
    if (from.length() > 12) from = "..." + from.substring(from.length()-7);
    // Trim body
    if (body.length() > 30) body = body.substring(0,29) + "~";

    msgs[count].from = from;
    msgs[count].body = body;
    msgs[count].date = date;
    count++;
    pos = be + 1;
  }
  return count;
}

// Main SMS screen
void runSMS() {
  applyTheme();

  // No credentials guard
  if (!twSID[0] || !twToken[0] || !twFrom[0]) {
    tft.fillScreen(COL_BG);
    tft.setTextColor(ST77XX_MAGENTA); tft.setTextSize(2);
    tft.setCursor(50, 30); tft.print("SMS");
    tft.setTextColor(ST77XX_RED); tft.setTextSize(1);
    tft.setCursor(10, 68); tft.print("Twilio credentials not set.");
    tft.setTextColor(COL_FG); tft.setCursor(10, 86);
    tft.print("Go to Settings > SMS tab to");
    tft.setCursor(10, 102); tft.print("enter your Account SID,");
    tft.setCursor(10, 118); tft.print("Auth Token, and From number.");
    tft.setTextColor(COL_ACCENT); tft.setCursor(10, 148);
    tft.print("Sign up free at twilio.com");
    tft.setCursor(10, 164); tft.print("(trial lets you send to verified");
    tft.setCursor(10, 180); tft.print("numbers at no charge)");
    tft.setTextColor(COL_DIM); tft.setCursor(10, 210);
    tft.print("MODE = back to menu");
    while (true) {
      if (btnPressed(BTN_MODE) || btnPressed(BTN_LEFT)) { currentState = STATE_MENU; return; }
      delay(10);
    }
  }

  // No WiFi guard
  if (WiFi.status() != WL_CONNECTED) {
    tft.fillScreen(COL_BG);
    tft.setTextColor(ST77XX_MAGENTA); tft.setTextSize(2);
    tft.setCursor(50, 30); tft.print("SMS");
    tft.setTextColor(ST77XX_RED); tft.setTextSize(1);
    tft.setCursor(10, 68); tft.print("Not connected to WiFi.");
    tft.setTextColor(COL_ACCENT); tft.setCursor(10, 88);
    tft.print("Go to Settings > WiFi to connect.");
    tft.setTextColor(COL_DIM); tft.setCursor(10, 118);
    tft.print("MODE = back to menu");
    while (true) {
      if (btnPressed(BTN_MODE) || btnPressed(BTN_LEFT)) { currentState = STATE_MENU; return; }
      delay(10);
    }
  }

  // SMS home: two options — Send | Inbox
  int opt = 0; // 0=Send  1=Inbox

  auto drawSmsHome = [&]() {
    tft.fillScreen(COL_BG);
    tft.setTextColor(ST77XX_MAGENTA); tft.setTextSize(2);
    tft.setCursor(68, 10); tft.print("SMS");
    tft.setTextColor(COL_ACCENT); tft.setTextSize(1);
    tft.setCursor(10, 36); tft.print("From: "); tft.print(twFrom);

    // Send card
    tft.fillRoundRect(14, 60, 212, 52, 8, opt==0 ? ST77XX_MAGENTA : COL_CARD);
    tft.drawRoundRect(14, 60, 212, 52, 8, opt==0 ? ST77XX_WHITE   : COL_DIM);
    tft.setTextSize(2); tft.setTextColor(opt==0 ? ST77XX_WHITE : COL_FG);
    tft.setCursor(74, 70); tft.print("Send");
    tft.setTextSize(1); tft.setTextColor(opt==0 ? ST77XX_WHITE : COL_ACCENT);
    tft.setCursor(28, 94); tft.print("Compose & send a new message");

    // Inbox card
    tft.fillRoundRect(14, 122, 212, 52, 8, opt==1 ? ST77XX_BLUE : COL_CARD);
    tft.drawRoundRect(14, 122, 212, 52, 8, opt==1 ? ST77XX_WHITE : COL_DIM);
    tft.setTextSize(2); tft.setTextColor(opt==1 ? ST77XX_WHITE : COL_FG);
    tft.setCursor(66, 132); tft.print("Inbox");
    tft.setTextSize(1); tft.setTextColor(opt==1 ? ST77XX_WHITE : COL_ACCENT);
    tft.setCursor(28, 156); tft.print("View last 10 received messages");

    tft.setTextColor(COL_DIM); tft.setTextSize(1);
    tft.setCursor(10, 190); tft.print("UP/DOWN = select   RIGHT = open");
    tft.setCursor(10, 204); tft.print("MODE = back to menu");
  };

  drawSmsHome();

  while (true) {
    if (btnPressed(BTN_UP))   { opt = 0; drawSmsHome(); }
    if (btnPressed(BTN_DOWN)) { opt = 1; drawSmsHome(); }
    if (btnPressed(BTN_MODE)) { currentState = STATE_MENU; return; }

    if (btnPressed(BTN_RIGHT)) {
      if (opt == 0) {
        // ---- SEND SMS ----
        String toNum = textEntry("To (e.g. +12025551234):", twLastTo);
        toNum.trim();
        if (toNum.length() < 7) { drawSmsHome(); continue; }

        String msgBody = textEntry("Message:", "");
        msgBody.trim();
        if (msgBody.length() == 0) { drawSmsHome(); continue; }

        // Save last-used To number
        toNum.toCharArray(twLastTo, 18);
        ee_writeMagic(); ee_writeStr(EE_TW_TO_ADDR, twLastTo, 18);

        // Show sending screen
        tft.fillScreen(COL_BG);
        tft.setTextColor(ST77XX_MAGENTA); tft.setTextSize(2);
        tft.setCursor(44, 10); tft.print("Sending...");
        tft.setTextColor(COL_ACCENT); tft.setTextSize(1);
        tft.setCursor(10, 40); tft.print("To: ");   tft.print(toNum);
        tft.setCursor(10, 56); tft.print("Msg: ");
        // Word-wrap message up to 3 lines
        String b = msgBody;
        for (int line = 0; line < 3 && b.length() > 0; line++) {
          String chunk = b.substring(0, min((int)b.length(), 30));
          b = (b.length() > 30) ? b.substring(30) : "";
          tft.setCursor(10, 72 + line*14); tft.print(chunk);
        }

        String err = twilioSend(toNum, msgBody);
        if (err.length() == 0) {
          smsStatusBanner("Sent!", ST77XX_GREEN);
        } else {
          smsStatusBanner("Error: " + err, ST77XX_RED);
        }
        delay(2500);
        drawSmsHome();

      } else {
        // ---- INBOX ----
        tft.fillScreen(COL_BG);
        tft.setTextColor(ST77XX_BLUE); tft.setTextSize(2);
        tft.setCursor(48, 10); tft.print("Inbox");
        tft.setTextColor(COL_ACCENT); tft.setTextSize(1);
        tft.setCursor(10, 34); tft.print("Fetching messages...");

        const int MAX_MSGS = 10;
        SmsMsg msgs[MAX_MSGS];
        int count = twilioFetchInbox(msgs, MAX_MSGS);

        tft.fillRect(0, 30, 240, 14, COL_BG);

        if (count == 0) {
          tft.setTextColor(ST77XX_RED); tft.setCursor(10, 50);
          tft.print("No messages or fetch failed.");
          tft.setTextColor(COL_ACCENT); tft.setCursor(10, 70);
          tft.print("Check credentials in Settings.");
          tft.setTextColor(COL_DIM); tft.setCursor(10, 200);
          tft.print("MODE or LEFT = back");
          while (true) {
            if (btnPressed(BTN_MODE) || btnPressed(BTN_LEFT)) { drawSmsHome(); break; }
            delay(10);
          }
        } else {
          int sel = 0;
          const int ROWS = 5;

          auto drawInbox = [&]() {
            tft.fillScreen(COL_BG);
            tft.setTextColor(ST77XX_BLUE); tft.setTextSize(1);
            tft.setCursor(4, 4);
            tft.print("Inbox ("); tft.print(count); tft.print(" msgs) U/D=scroll MODE=back");
            tft.drawFastHLine(0, 14, 240, COL_DIM);

            int startIdx = sel - 2;
            if (startIdx < 0) startIdx = 0;
            if (startIdx > count - ROWS) startIdx = max(0, count - ROWS);

            for (int i = 0; i < ROWS && (startIdx+i) < count; i++) {
              int idx = startIdx + i;
              bool isSel = (idx == sel);
              int ry = 18 + i*43;
              tft.fillRoundRect(2, ry, 236, 40, 3, isSel ? 0x0018 : COL_CARD);
              tft.drawRoundRect(2, ry, 236, 40, 3, isSel ? ST77XX_BLUE : COL_DIM);

              // From + time
              tft.setTextColor(isSel ? ST77XX_CYAN : COL_ACCENT);
              tft.setCursor(6, ry+4); tft.print(msgs[idx].from);
              tft.setTextColor(COL_DIM);
              tft.setCursor(180, ry+4); tft.print(msgs[idx].date);

              // Body
              tft.setTextColor(isSel ? ST77XX_WHITE : COL_FG);
              tft.setCursor(6, ry+20); tft.print(msgs[idx].body);
            }
            tft.setTextColor(COL_DIM); tft.setTextSize(1);
            tft.setCursor(4, 234); tft.print(String(sel+1)+"/"+String(count)+"  MODE=back");
          };

          drawInbox();
          while (true) {
            if (btnPressed(BTN_UP))   { if (sel > 0)       { sel--; drawInbox(); } }
            if (btnPressed(BTN_DOWN)) { if (sel < count-1) { sel++; drawInbox(); } }
            if (btnPressed(BTN_MODE) || btnPressed(BTN_LEFT)) { drawSmsHome(); break; }
            delay(10);
          }
        }
      }
    }

    delay(10);
  }
}

// ======================================================
//  S E T U P   &   L O O P
// ======================================================
void setup() {
  Serial.begin(115200);

  pinMode(BTN_LEFT,  INPUT_PULLUP);
  pinMode(BTN_UP,    INPUT_PULLUP);
  pinMode(BTN_RIGHT, INPUT_PULLUP);
  pinMode(BTN_DOWN,  INPUT_PULLUP);
  pinMode(BTN_MODE,  INPUT_PULLUP);

  EEPROM.begin(EE_TOTAL);  // Required on ESP32 — must call before any EEPROM access

  tft.init(SCREEN_WIDTH, SCREEN_HEIGHT);
  tft.setRotation(2);

  // Load all saved settings first
  ee_loadAll();
  applyTheme();
  tft.fillScreen(COL_BG);

  randomSeed(analogRead(A0));

  // Restore BLE advertising if it was on last session
  if (bleAdvertising) bleStart();

  // Auto-connect WiFi if credentials were saved
  if (savedSSID[0] != 0) {
    tft.setTextColor(COL_FG); tft.setTextSize(1);
    tft.setCursor(10, 96);  tft.print("Connecting to WiFi...");
    tft.setTextColor(ST77XX_CYAN); tft.setCursor(10, 112);
    tft.print(savedSSID);
    WiFi.begin(savedSSID, savedPass);
    unsigned long t0 = millis();
    while (WiFi.status() != WL_CONNECTED && millis()-t0 < 8000) delay(200);
    tft.fillScreen(COL_BG);
    if (WiFi.status() == WL_CONNECTED) {
      // Sync NTP — Chicago Central Time, auto-handles DST
      configTzTime("CST6CDT,M3.2.0,M11.1.0", "pool.ntp.org");
    }
  }

  currentState = STATE_MENU;
}

void loop() {
  switch (currentState) {
    case STATE_MENU:     runMenu();     break;
    case STATE_2048:     run2048();     currentState = STATE_MENU; break;
    case STATE_TETRIS:   runTetris();   currentState = STATE_MENU; break;
    case STATE_PONG:     runPong();     currentState = STATE_MENU; break;
    case STATE_WEATHER:  runWeather();  break;
    case STATE_SMS:      runSMS();      break;
    case STATE_SETTINGS: runSettings(); break;
  }
}
