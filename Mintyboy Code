void runGames(){
  const char* names[]={"2048","Tetris","Pong","Flappy","Snake","Breakout","Minesweep","Simon"};
  const uint16_t colors[]={0xEAC0,ST77XX_CYAN,ST77XX_GREEN,0xFD20,ST77XX_GREEN,ST77XX_ORANGE,ST77XX_YELLOW,ST77XX_MAGENTA};
  int sel=0;
  auto draw=[&](){
    tft.fillScreen(COL_BG);tft.setTextSize(2);tft.setTextColor(COL_FG);
    tft.setCursor(52,4);tft.print("GAMES");
    tft.setTextSize(1);tft.setTextColor(COL_ACCENT);
    tft.setCursor(14,22);tft.print("UP/DOWN=select  RIGHT=play  MODE=back");
    tft.drawFastHLine(0,32,240,COL_DIM);
    for(int i=0;i<8;i++){
      int cy=38+i*25;bool s=(i==sel);
      tft.fillRoundRect(8,cy,224,22,4,s?colors[i]:COL_CARD);
      tft.drawRoundRect(8,cy,224,22,4,s?ST77XX_WHITE:COL_DIM);
      tft.setTextSize(s?2:1);tft.setTextColor(s?ST77XX_BLACK:COL_FG);
      tft.setCursor(8+(224-(int)strlen(names[i])*6*(s?2:1))/2,cy+(s?3:7));
      tft.print(names[i]);
    }
  };
  draw();
  while(true){
    if(btnPressed(BTN_UP))  {sel=(sel+7)%8;draw();}
    if(btnPressed(BTN_DOWN)){sel=(sel+1)%8;draw();}
    if(btnPressed(BTN_RIGHT)||btnPressed(BTN_LEFT)){
      switch(sel){
        case 0:currentState=STATE_2048;      break;
        case 1:currentState=STATE_TETRIS;    break;
        case 2:currentState=STATE_PONG;      break;
        case 3:currentState=STATE_FLAPPY;    break;
        case 4:currentState=STATE_SNAKE;     break;
        case 5:currentState=STATE_BREAKOUT;  break;
        case 6:currentState=STATE_MINESWEEPER;break;
        case 7:currentState=STATE_SIMON;     break;
      }
      return;
    }
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}
    delay(10);
  }
}

