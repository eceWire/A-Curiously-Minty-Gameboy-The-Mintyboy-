void applyTheme() {
  if (darkTheme) {
    COL_BG     = ST77XX_BLACK;
    COL_FG     = ST77XX_WHITE;
    COL_DIM    = 0x4208;
    COL_ACCENT = 0x8410;
    COL_CARD   = 0x1082;
  } else {
    COL_BG     = ST77XX_WHITE;
    COL_FG     = 0x0841;
    COL_DIM    = 0xC618;
    COL_ACCENT = 0x7BEF;
    COL_CARD   = 0xDEDB;
  }
}

// ======================================================
//  BLE HELPERS
// ======================================================
void bleStart() {
  if (!bleInitDone) {
    BLEDevice::init("NanoESP32-Games");
    pBLEAdvert = BLEDevice::getAdvertising();
    bleInitDone = true;
  }
  if (pBLEAdvert) { pBLEAdvert->start(); bleAdvertising = true; }
}

void bleStop() {
  if (pBLEAdvert) { pBLEAdvert->stop(); bleAdvertising = false; }
}

String bleAddress() {
  if (!bleInitDone) { BLEDevice::init("NanoESP32-Games"); bleInitDone = true; }
  return String(BLEDevice::getAddress().toString().c_str());
}

// ======================================================
//  EEPROM HELPERS
// ======================================================
bool ee_valid() {
  return EEPROM.read(EE_MAGIC_ADDR)   == EE_MAGIC_0 &&
         EEPROM.read(EE_MAGIC_ADDR+1) == EE_MAGIC_1;
}

void ee_writeMagic() {
  EEPROM.write(EE_MAGIC_ADDR,   EE_MAGIC_0);
  EEPROM.write(EE_MAGIC_ADDR+1, EE_MAGIC_1);
  EEPROM.commit();
}

void ee_writeStr(int addr, const char* s, int maxLen) {
  for (int i = 0; i < maxLen-1; i++) {
    EEPROM.write(addr+i, (uint8_t)s[i]);
    if (!s[i]) break;
  }
  EEPROM.write(addr+maxLen-1, 0);
  EEPROM.commit();
}

void ee_readStr(int addr, char* buf, int maxLen) {
  for (int i = 0; i < maxLen; i++) {
    buf[i] = (char)EEPROM.read(addr+i);
    if (!buf[i]) break;
  }
  buf[maxLen-1] = 0;
}

void ee_loadAll() {
  if (!ee_valid()) return;
  g_bestScore = (uint32_t)EEPROM.read(EE_BEST_ADDR)
              | (uint32_t)EEPROM.read(EE_BEST_ADDR+1) << 8
              | (uint32_t)EEPROM.read(EE_BEST_ADDR+2) << 16
              | (uint32_t)EEPROM.read(EE_BEST_ADDR+3) << 24;
  ee_readStr(EE_SSID_ADDR,    savedSSID,    34);
  ee_readStr(EE_PASS_ADDR,    savedPass,    66);
  ee_readStr(EE_CITY_ADDR,    weatherCity,  34);
  if (weatherCity[0] == 0) strcpy(weatherCity, "London");
  ee_readStr(EE_TW_SID_ADDR,  twSID,        36);
  ee_readStr(EE_TW_TOK_ADDR,  twToken,      34);
  ee_readStr(EE_TW_FROM_ADDR, twFrom,       18);
  ee_readStr(EE_TW_TO_ADDR,   twLastTo,     18);
  darkTheme      = (EEPROM.read(EE_THEME_ADDR) != 1);
  bleAdvertising = (EEPROM.read(EE_BLE_ADDR)   == 1);
}

int ee_countUsed() {
  int n = 0;
  for (int i = 0; i < EE_TOTAL; i++)
    if (EEPROM.read(i) != 0xFF) n++;
  return n;
}

void ee_eraseAll() {
  for (int i = 0; i < EE_TOTAL; i++) EEPROM.write(i, 0xFF);
  EEPROM.commit();
  g_bestScore = 0;
  savedSSID[0] = savedPass[0] = 0;
  darkTheme = true; bleAdvertising = false;
  strcpy(weatherCity, "London");
  applyTheme();
}

// ======================================================
//  DEBOUNCE
// ======================================================
unsigned long _lastDebounce = 0;
const unsigned long DEBOUNCE_MS = 160;

bool btnPressed(int pin) {
  if (digitalRead(pin) == LOW) {
    unsigned long t = millis();
    if (t - _lastDebounce > DEBOUNCE_MS) {
      _lastDebounce = t;
      while (digitalRead(pin) == LOW) delay(5);
      return true;
    }
  }
  return false;
}

bool anyBtnPressed() {
  return digitalRead(BTN_LEFT)  == LOW || digitalRead(BTN_UP)    == LOW ||
         digitalRead(BTN_RIGHT) == LOW || digitalRead(BTN_DOWN)  == LOW ||
         digitalRead(BTN_MODE)  == LOW;
}
void waitAllReleased() { while (anyBtnPressed()) delay(10); }
void waitAnyPress()    { waitAllReleased(); while (!anyBtnPressed()) delay(10); waitAllReleased(); }

// ======================================================
//  TEXT ENTRY — on-screen character wheel
//  UP/DOWN = cycle char   RIGHT = add char   LEFT = backspace
//  Hold MODE 1.5 s = confirm and return entered string
// ======================================================
// ======================================================
//  GRID KEYBOARD
//  Layout: 5 rows of 10 chars (QWERTY-style) + special row
//  UP/DOWN = move row   LEFT/RIGHT = move column
//  MODE tap = type that key   MODE hold 1.5s = done/confirm
//  Password mode: shows *** instead of typed chars
// ======================================================
const char* KB_NORM[5] = {
  "1234567890",
  "qwertyuiop",
  "asdfghjkl-",
  "zxcvbnm,.!",
  "@#$%&*+=?/"
};
const char* KB_SHFT[5] = {
  "1234567890",
  "QWERTYUIOP",
  "ASDFGHJKL-",
  "ZXCVBNM,.!",
  "@#$%&*+=?/"
};

String textEntry(const char* prompt, const char* initial, bool hideInput = false) {
  const int NUM_ROWS  = 5;
  const int NUM_COLS  = 10;
  const int SPEC_ROW  = 5;
  const int NUM_SPEC  = 4;

  bool   shifted = false;
  String result  = String(initial);
  int    curRow  = 1, curCol = 0;

  const int KB_X   = 1;
  const int KB_Y   = 30;
  const int CW     = 23;
  const int CH     = 20;
  const int GAP    = 1;
  const int SPEC_Y = KB_Y + NUM_ROWS * (CH + GAP) + 3;
  const int SW[4]  = { 79, 51, 51, 57 };

  auto drawKB = [&]() {
    tft.fillScreen(COL_BG);

    tft.setTextColor(COL_FG); tft.setTextSize(1);
    char pb[38]; strncpy(pb, prompt, 37); pb[37] = 0;
    tft.setCursor(3, 3); tft.print(pb);

    tft.fillRoundRect(2, 13, 236, 15, 2, COL_CARD);
    tft.drawRoundRect(2, 13, 236, 15, 2, COL_DIM);
    tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1);
    tft.setCursor(5, 18);
    if (hideInput) {
      int shown = min((int)result.length(), 37);
      for (int i = 0; i < shown; i++) tft.print('*');
    } else {
      String disp = result;
      if (disp.length() > 37) disp = disp.substring(disp.length() - 37);
      tft.print(disp);
    }
    tft.setTextColor(ST77XX_WHITE); tft.print('|');

    const char** kb = shifted ? KB_SHFT : KB_NORM;
    for (int r = 0; r < NUM_ROWS; r++) {
      for (int c = 0; c < NUM_COLS; c++) {
        int x   = KB_X + c * (CW + GAP);
        int y   = KB_Y + r * (CH + GAP);
        bool sel = (curRow == r && curCol == c);
        tft.fillRect(x, y, CW, CH, sel ? ST77XX_BLUE : COL_CARD);
        if (sel) tft.drawRect(x, y, CW, CH, ST77XX_WHITE);
        tft.setTextColor(sel ? ST77XX_WHITE : COL_FG); tft.setTextSize(1);
        tft.setCursor(x + (CW - 6) / 2, y + (CH - 8) / 2);
        tft.print(kb[r][c]);
      }
    }

    const char*  spLbl[4] = { "SPACE", "CAPS", "DEL", "DONE" };
    uint16_t     spBg[4]  = {
      COL_CARD,
      (uint16_t)(shifted ? ST77XX_ORANGE : COL_CARD),
      (uint16_t)0x8000,
      (uint16_t)0x0410
    };
    int sx = 2;
    for (int i = 0; i < NUM_SPEC; i++) {
      bool sel = (curRow == SPEC_ROW && curCol == i);
      tft.fillRoundRect(sx, SPEC_Y, SW[i] - 2, CH, 3, sel ? ST77XX_BLUE : spBg[i]);
      if (sel) tft.drawRoundRect(sx, SPEC_Y, SW[i] - 2, CH, 3, ST77XX_WHITE);
      tft.setTextColor(sel ? ST77XX_WHITE : (i == 3 ? ST77XX_WHITE : COL_FG));
      tft.setTextSize(1);
      int lw = strlen(spLbl[i]) * 6;
      tft.setCursor(sx + (SW[i] - 2 - lw) / 2, SPEC_Y + (CH - 8) / 2);
      tft.print(spLbl[i]);
      sx += SW[i];
    }

    tft.setTextColor(COL_DIM); tft.setTextSize(1);
    tft.setCursor(3, 230);
    tft.print("D-pad=navigate  MODE=type  hold=done");
  };

  drawKB();

  while (true) {
    bool moved = false;
    if (btnPressed(BTN_UP)) {
      if      (curRow == SPEC_ROW)    { curRow = NUM_ROWS - 1; if (curCol >= NUM_COLS) curCol = NUM_COLS - 1; }
      else if (curRow > 0)            { curRow--; }
      moved = true;
    }
    if (btnPressed(BTN_DOWN)) {
      if      (curRow < NUM_ROWS - 1) { curRow++; }
      else if (curRow == NUM_ROWS - 1){ curRow = SPEC_ROW; if (curCol >= NUM_SPEC) curCol = 0; }
      moved = true;
    }
    if (btnPressed(BTN_LEFT)) {
      int cols = (curRow == SPEC_ROW) ? NUM_SPEC : NUM_COLS;
      curCol = (curCol + cols - 1) % cols;
      moved = true;
    }
    if (btnPressed(BTN_RIGHT)) {
      int cols = (curRow == SPEC_ROW) ? NUM_SPEC : NUM_COLS;
      curCol = (curCol + 1) % cols;
      moved = true;
    }
    if (moved) drawKB();

    if (digitalRead(BTN_MODE) == LOW) {
      unsigned long t0 = millis();
      while (digitalRead(BTN_MODE) == LOW) {
        if (millis() - t0 > 1500) { waitAllReleased(); return result; }
        delay(10);
      }
      if (curRow < NUM_ROWS) {
        const char** kb = shifted ? KB_SHFT : KB_NORM;
        if (result.length() < 63) result += kb[curRow][curCol];
        shifted = false;
      } else {
        switch (curCol) {
          case 0: if (result.length() < 63) result += ' ';                   break;
          case 1: shifted = !shifted;                                          break;
          case 2: if (result.length() > 0) result.remove(result.length()-1); break;
          case 3: return result;
        }
      }
      drawKB();
    }
    delay(10);
  }
}

// ======================================================
//  MENU  (6 items: 2048 | Tetris | Pong | Weather | SMS | Settings)
// ======================================================
const char*    menuNames[]  = { "2048", "Tetris", "Pong", "Weather", "SMS", "Settings" };
const uint16_t menuColors[] = { 0xEAC0, ST77XX_CYAN, ST77XX_GREEN, 0x051F, 0xF81F, 0xC618 };
const int NUM_ITEMS = 6;
int menuSel = 0;

void drawMenuClock() {
  struct tm t;
  if (!getLocalTime(&t, 0)) return;  // non-blocking; skip if not synced yet
  char timebuf[10];
  strftime(timebuf, sizeof(timebuf), "%I:%M %p", &t);  // "02:34 PM"
  char datebuf[12];
  strftime(datebuf, sizeof(datebuf), "%a %b %d", &t);  // "Sat Jun 14"
  // Top-right: time (clear 88x14 px area to avoid ghosting)
  tft.fillRect(152, 2, 88, 14, COL_BG);
  tft.setTextColor(ST77XX_YELLOW); tft.setTextSize(1);
  tft.setCursor(156, 6); tft.print(timebuf);
  // Right of WiFi row: date
  tft.fillRect(140, 34, 100, 10, COL_BG);
  tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1);
  tft.setCursor(142, 34); tft.print(datebuf);
}

void drawMenu() {
  tft.fillScreen(COL_BG);
  tft.setTextSize(2); tft.setTextColor(COL_FG);
  tft.setCursor(20, 2); tft.print("GAME SELECT");
  tft.setTextSize(1); tft.setTextColor(COL_ACCENT);
  tft.setCursor(14, 22); tft.print("< L/R > browse    DOWN = enter");

  bool wfConn = (WiFi.status() == WL_CONNECTED);
  tft.setTextColor(wfConn ? ST77XX_GREEN : COL_DIM);
  tft.setCursor(6, 34);
  if (wfConn) { tft.print("WiFi: "); tft.print(WiFi.SSID()); }
  else         { tft.print("WiFi: disconnected"); }

  // 6 items — 32 px cards with 2 px gap, starting at y=44
  for (int i = 0; i < NUM_ITEMS; i++) {
    int cX=8, cY=44+i*33, cW=224, cH=28;
    bool sel = (i == menuSel);
    uint16_t bg  = sel ? menuColors[i] : COL_CARD;
    uint16_t fg  = sel ? ST77XX_BLACK  : COL_FG;
    uint16_t bdr = sel ? ST77XX_WHITE  : COL_DIM;
    tft.fillRoundRect(cX,cY,cW,cH,4,bg);
    tft.drawRoundRect(cX,cY,cW,cH,4,bdr);
    tft.setTextSize(1); tft.setTextColor(fg);
    // Use size-2 text for short names, size-1 for longer
    uint8_t ts = (strlen(menuNames[i]) <= 8) ? 2 : 1;
    tft.setTextSize(ts);
    int tx = cX + (cW - (int)strlen(menuNames[i])*6*ts) / 2;
    int ty = cY + (cH - 8*ts) / 2;
    tft.setCursor(tx, ty); tft.print(menuNames[i]);
  }
}

void runMenu() {
  applyTheme(); drawMenu(); drawMenuClock();
  unsigned long lastClockMs = 0;
  while (true) {
    unsigned long nowMs = millis();
    if (nowMs - lastClockMs >= 1000) { drawMenuClock(); lastClockMs = nowMs; }
    if (btnPressed(BTN_LEFT))  { menuSel=(menuSel+NUM_ITEMS-1)%NUM_ITEMS; drawMenu(); drawMenuClock(); lastClockMs=millis(); }
    if (btnPressed(BTN_RIGHT)) { menuSel=(menuSel+1)%NUM_ITEMS;           drawMenu(); drawMenuClock(); lastClockMs=millis(); }
    if (btnPressed(BTN_DOWN) || btnPressed(BTN_UP) || btnPressed(BTN_MODE)) break;
    delay(10);
  }
  switch (menuSel) {
    case 0: currentState = STATE_2048;     break;
    case 1: currentState = STATE_TETRIS;   break;
    case 2: currentState = STATE_PONG;     break;
    case 3: currentState = STATE_WEATHER;  break;
    case 4: currentState = STATE_SMS;      break;
    case 5: currentState = STATE_SETTINGS; break;
  }
}

String enterPassword(const String& ssid) {
  String prompt = "Password for: " + ssid;
  return textEntry(prompt.c_str(), "", true);
}

// ======================================================
//  WIFI SCANNER + PASSWORD ENTRY
// ======================================================
void runWifiSettings() {
  int n = 0;

  doScan:
  tft.fillScreen(COL_BG);
  tft.setTextColor(COL_FG); tft.setTextSize(2);
  tft.setCursor(22, 26); tft.print("Scanning WiFi");
  tft.setTextSize(1); tft.setTextColor(COL_ACCENT);
  tft.setCursor(20, 58); tft.print("Please wait...");

  // Properly reset radio before scanning
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();   // single-arg: just disconnect, keep radio alive
  delay(1500);         // give radio time to settle

  n = WiFi.scanNetworks(false, true); // false=blocking, true=show hidden

  if (n <= 0) {
    tft.fillScreen(COL_BG);
    tft.setTextColor(ST77XX_RED); tft.setTextSize(1);
    tft.setCursor(10, 80);  tft.print("No networks found.");
    tft.setTextColor(COL_FG);
    tft.setCursor(10, 102); tft.print("Tips:");
    tft.setCursor(10, 116); tft.print("- Move closer to your router");
    tft.setCursor(10, 130); tft.print("- Check antenna is attached");
    tft.setCursor(10, 144); tft.print("- 2.4 GHz networks only");
    tft.setTextColor(ST77XX_YELLOW);
    tft.setCursor(10, 168); tft.print("RIGHT = scan again");
    tft.setCursor(10, 182); tft.print("MODE  = back");
    while (true) {
      if (btnPressed(BTN_RIGHT)) goto doScan;
      if (btnPressed(BTN_MODE))  return;
      delay(10);
    }
  }

  int sel = 0;
  const int MAX_SHOW = 8;

  auto drawList = [&]() {
    tft.fillScreen(COL_BG);
    tft.setTextColor(COL_FG); tft.setTextSize(1);
    tft.setCursor(4, 4);
    tft.print("WiFi: U/D=scroll  R=connect  MODE=back");
    tft.drawFastHLine(0, 14, 240, COL_DIM);

    int startIdx = sel - 3;
    if (startIdx < 0) startIdx = 0;
    int maxStart = n - MAX_SHOW;
    if (maxStart < 0) maxStart = 0;
    if (startIdx > maxStart) startIdx = maxStart;

    for (int i = 0; i < MAX_SHOW && (startIdx+i) < n; i++) {
      int idx = startIdx + i;
      bool isSel = (idx == sel);
      int ry = 18 + i*26;

      tft.fillRoundRect(4, ry, 232, 22, 3, isSel ? ST77XX_BLUE : COL_CARD);
      tft.setTextColor(isSel ? ST77XX_WHITE : COL_FG);
      tft.setCursor(8, ry+7);

      String ssid = WiFi.SSID(idx);
      if (ssid.length() > 24) ssid = ssid.substring(0,23) + "~";
      tft.print(ssid);

      int rssi = WiFi.RSSI(idx);
      const char* sig =
        (rssi > -55) ? "Ex" :
        (rssi > -70) ? "Ok" : "Lo";

      tft.setCursor(190, ry+7);
      tft.print(sig);
    }
  };

  drawList();

  while (true) {
    if (btnPressed(BTN_UP))   { sel = (sel + n - 1) % n; drawList(); }
    if (btnPressed(BTN_DOWN)) { sel = (sel + 1) % n;     drawList(); }

    if (btnPressed(BTN_RIGHT)) {
      String ssid = WiFi.SSID(sel);
      String password = enterPassword(ssid);

      tft.fillScreen(COL_BG);
      tft.setTextColor(COL_FG); tft.setTextSize(1);
      tft.setCursor(10, 70); tft.print("Connecting to:");
      tft.setCursor(10, 86); tft.print(ssid);

      WiFi.begin(ssid.c_str(), password.c_str());
      unsigned long t0 = millis();
      while (WiFi.status() != WL_CONNECTED && millis() - t0 < 12000) {
        delay(300);
      }

      if (WiFi.status() == WL_CONNECTED) {
        strncpy(savedSSID, ssid.c_str(), sizeof(savedSSID));
        strncpy(savedPass, password.c_str(), sizeof(savedPass));
        ee_writeStr(EE_SSID_ADDR, savedSSID, 34);
        ee_writeStr(EE_PASS_ADDR, savedPass, 66);
        ee_writeMagic();
        tft.fillScreen(COL_BG);
        tft.setTextColor(ST77XX_GREEN); tft.setTextSize(1);
        tft.setCursor(10, 80); tft.print("Connected!");
        tft.setCursor(10, 96); tft.print(WiFi.localIP().toString());
        delay(2000);
        return;
      } else {
