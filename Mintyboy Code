void ms_drawAll(){
  tft.fillScreen(COL_BG);
  tft.setTextColor(COL_FG);tft.setTextSize(1);
  tft.setCursor(4,4);tft.print("MINESWEEPER  U/D/L/R=move  R=reveal  D=flag");
  tft.setCursor(4,14);tft.print("Mines:");tft.print(MS_MINES);tft.print("  Score:");tft.print(ms_score);tft.print("  MODE=menu");
  for(int r=0;r<MS_ROWS;r++) for(int c=0;c<MS_COLS;c++) ms_drawCell(c,r);
}

void ms_reveal(int cx,int cy){
  if(cx<0||cx>=MS_COLS||cy<0||cy>=MS_ROWS)return;
  if(ms_revealed[cy][cx]||ms_flagged[cy][cx])return;
  ms_revealed[cy][cx]=true;
  if(ms_board[cy][cx]==9){ms_dead=true;return;}
  if(ms_board[cy][cx]==0){
    ms_score++;
    for(int dy=-1;dy<=1;dy++) for(int dx=-1;dx<=1;dx++) if(dx||dy) ms_reveal(cx+dx,cy+dy);
  } else {ms_score+=ms_board[cy][cx];}
}

void ms_init(){
  memset(ms_board,0,sizeof(ms_board));
  memset(ms_revealed,0,sizeof(ms_revealed));
  memset(ms_flagged,0,sizeof(ms_flagged));
  ms_curX=MS_COLS/2;ms_curY=MS_ROWS/2;ms_score=0;ms_dead=false;ms_won=false;
  // Place mines
  int placed=0;
  while(placed<MS_MINES){int x=random(MS_COLS),y=random(MS_ROWS);if(ms_board[y][x]!=9){ms_board[y][x]=9;placed++;}}
  // Count neighbours
  for(int r=0;r<MS_ROWS;r++) for(int c=0;c<MS_COLS;c++){
    if(ms_board[r][c]==9)continue;
    int cnt=0;
    for(int dy=-1;dy<=1;dy++) for(int dx=-1;dx<=1;dx++){int nc=c+dx,nr=r+dy;if(nc>=0&&nc<MS_COLS&&nr>=0&&nr<MS_ROWS&&ms_board[nr][nc]==9)cnt++;}
    ms_board[r][c]=cnt;
  }
}

void runMinesweeper(){
  applyTheme();ms_init();ms_drawAll();
  while(true){
    bool moved=false;
    if(btnPressed(BTN_LEFT)) {ms_curX=(ms_curX+MS_COLS-1)%MS_COLS;moved=true;}
    if(btnPressed(BTN_RIGHT)){ms_curX=(ms_curX+1)%MS_COLS;         moved=true;}
    if(btnPressed(BTN_UP))   {ms_curY=(ms_curY+MS_ROWS-1)%MS_ROWS; moved=true;}
    if(btnPressed(BTN_DOWN)) {ms_curY=(ms_curY+1)%MS_ROWS;         moved=true;}
    if(moved){ms_drawCell((ms_curX+1)%MS_COLS,ms_curY);ms_drawCell((ms_curX-1+MS_COLS)%MS_COLS,ms_curY);ms_drawCell(ms_curX,ms_curY);tft.setTextColor(COL_FG);tft.setTextSize(1);tft.setCursor(4,14);tft.fillRect(0,14,240,10,COL_BG);tft.print("Mines:");tft.print(MS_MINES);tft.print("  Score:");tft.print(ms_score);}

    // Right = reveal, Down = flag (when on selected cell)
    if(digitalRead(BTN_RIGHT)==LOW&&digitalRead(BTN_DOWN)==LOW){
      // both = flag
      delay(200);waitAllReleased();
      if(!ms_revealed[ms_curY][ms_curX])ms_flagged[ms_curY][ms_curX]=!ms_flagged[ms_curY][ms_curX];
      ms_drawCell(ms_curX,ms_curY);
    } else if(btnPressed(BTN_MODE)){
      // MODE = reveal
      if(!ms_flagged[ms_curY][ms_curX]){ms_reveal(ms_curX,ms_curY);ms_drawAll();}
    }

    if(ms_dead){buzzGameOver();
      // Reveal all mines
      for(int r=0;r<MS_ROWS;r++)for(int c=0;c<MS_COLS;c++)if(ms_board[r][c]==9)ms_revealed[r][c]=true;
      ms_drawAll();
