void sw_fmt(unsigned long ms,char* buf){
  unsigned long totalSec=ms/1000,centis=(ms%1000)/10,secs=totalSec%60,mins=(totalSec/60)%60,hrs=totalSec/3600;
  if(hrs>0)sprintf(buf,"%lu:%02lu:%02lu.%02lu",hrs,mins,secs,centis);
  else sprintf(buf,"%02lu:%02lu.%02lu",mins,secs,centis);
}
