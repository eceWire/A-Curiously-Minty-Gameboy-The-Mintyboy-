void fb_eraseBg(int x,int y,int w,int h){if(x<0){w+=x;x=0;}if(y<0){h+=y;y=0;}if(x+w>240)w=240-x;if(y+h>240)h=240-y;if(w<=0||h<=0)return;int bot=y+h,mid=FB_GROUND_Y/2;int y0=y,y1=(mid<bot)?mid:bot;if(y1>y0)tft.fillRect(x,y0,w,y1-y0,FB_SKY2);y0=(mid>y)?mid:y;y1=(FB_GROUND_Y<bot)?FB_GROUND_Y:bot;if(y1>y0)tft.fillRect(x,y0,w,y1-y0,FB_SKY);y0=(FB_GROUND_Y>y)?FB_GROUND_Y:y;if(y0<bot){int gb=y0+5;if(gb>bot)gb=bot;tft.fillRect(x,y0,w,gb-y0,FB_GRASS_C);if(gb<bot)tft.fillRect(x,gb,w,bot-gb,FB_GROUND_C);}}
void fb_drawPipe(int x,int topH){if(x+FB_PIPE_W+3<0||x-3>=240)return;int bt=topH+FB_PIPE_GAP,bh=FB_GROUND_Y-bt,cx=x-3,cw=FB_PIPE_W+6;tft.fillRect(x,0,FB_PIPE_W,topH,FB_PIPE_C);tft.fillRect(x,0,3,topH,FB_PIPE_LIT);tft.fillRect(x+FB_PIPE_W-3,0,3,topH,FB_PIPE_DARK);if(cx<240&&cx+cw>0){tft.fillRect(cx,topH-12,cw,12,FB_PIPE_CAP);}if(bh>0){tft.fillRect(x,bt,FB_PIPE_W,bh,FB_PIPE_C);if(cx<240&&cx+cw>0){tft.fillRect(cx,bt,cw,12,FB_PIPE_CAP);}}}
void fb_erasePipe(int px){int ex=px+FB_PIPE_W-1,ew=FB_PIPE_SPD+4;if(ex>=240)return;if(ex+ew>240)ew=240-ex;fb_eraseBg(ex,0,ew,FB_GROUND_Y);int cx2=px-3;if(cx2>=0)fb_eraseBg(cx2,0,FB_PIPE_SPD+2,FB_GROUND_Y);}
void fb_hud(uint16_t sc){tft.fillRect(75,4,90,26,FB_SKY2);int cx2=120-(sc<10?9:sc<100?18:27);tft.setTextSize(3);tft.setTextColor(0x0000);tft.setCursor(cx2+1,11);tft.print(sc);tft.setTextColor(0xFFFF);tft.setCursor(cx2,10);tft.print(sc);}
void fb_bg(){tft.fillRect(0,0,240,FB_GROUND_Y/2,FB_SKY2);tft.fillRect(0,FB_GROUND_Y/2,240,FB_GROUND_Y-FB_GROUND_Y/2,FB_SKY);tft.fillCircle(195,28,16,FB_SUN);tft.fillRect(0,FB_GROUND_Y,240,240-FB_GROUND_Y,FB_GROUND_C);tft.fillRect(0,FB_GROUND_Y,240,5,FB_GRASS_C);}
void fb_drawBird(int wx,int wy){int tilt=(fb_birdVel>2.5f)?2:(fb_birdVel<-2.5f)?-2:0;tft.fillRoundRect(wx,wy+tilt,FB_BIRD_W,FB_BIRD_H,4,ST77XX_YELLOW);tft.fillCircle(wx+FB_BIRD_W-4,wy+tilt+3,3,ST77XX_WHITE);tft.fillCircle(wx+FB_BIRD_W-3,wy+tilt+3,2,ST77XX_BLACK);tft.fillRect(wx+FB_BIRD_W,wy+tilt+5,5,4,ST77XX_ORANGE);}
void fb_loadHi(){for(int i=0;i<FB_NUM_SCR;i++){uint16_t v=((uint16_t)EEPROM.read(EE_FB_ADDR+i*2)<<8)|EEPROM.read(EE_FB_ADDR+i*2+1);fb_hi[i]=(v==0xFFFF)?0:v;}}
void fb_saveHi(uint16_t sc){for(int i=0;i<FB_NUM_SCR;i++){if(sc>fb_hi[i]){for(int j=FB_NUM_SCR-1;j>i;j--)fb_hi[j]=fb_hi[j-1];fb_hi[i]=sc;break;}}for(int i=0;i<FB_NUM_SCR;i++){EEPROM.write(EE_FB_ADDR+i*2,fb_hi[i]>>8);EEPROM.write(EE_FB_ADDR+i*2+1,fb_hi[i]&0xFF);}EEPROM.commit();}
void fb_update(){fb_birdVel+=FB_GRAVITY;fb_birdY+=fb_birdVel;if(millis()-fb_animTimer>110){fb_animTimer=millis();fb_birdFrame=(fb_birdFrame+1)%3;}for(int i=0;i<FB_MAX_PIPES;i++){fb_pipes[i].prevX=fb_pipes[i].x;fb_pipes[i].x-=FB_PIPE_SPD;if(!fb_pipes[i].scored&&fb_pipes[i].x+FB_PIPE_W<FB_BIRD_X){fb_pipes[i].scored=true;fb_score++;buzzPoints();}if(fb_pipes[i].x+FB_PIPE_W<0){fb_pipes[i].x=fb_pipes[i].prevX=240+10;fb_pipes[i].topH=random(30,FB_GROUND_Y-FB_PIPE_GAP-30);fb_pipes[i].scored=false;}}int bx1=FB_BIRD_X+2,bx2=FB_BIRD_X+FB_BIRD_W-2;int by1=(int)fb_birdY+2,by2=(int)fb_birdY+FB_BIRD_H-2;if(by2>=FB_GROUND_Y||by1<=0){fb_saveHi(fb_score);fb_state=FB_DEAD;fb_deadTimer=millis();buzzGameOver();return;}for(int i=0;i<FB_MAX_PIPES;i++)if(bx2>fb_pipes[i].x&&bx1<fb_pipes[i].x+FB_PIPE_W)if(by1<fb_pipes[i].topH||by2>fb_pipes[i].topH+FB_PIPE_GAP){fb_saveHi(fb_score);fb_state=FB_DEAD;fb_deadTimer=millis();buzzGameOver();return;}}
void fb_drawFast(){for(int i=0;i<FB_MAX_PIPES;i++){if(fb_pipes[i].x!=fb_pipes[i].prevX){fb_erasePipe(fb_pipes[i].prevX);fb_drawPipe(fb_pipes[i].x,fb_pipes[i].topH);}}fb_drawBird(FB_BIRD_X,(int)fb_birdY);if(fb_score!=fb_prevScore){fb_hud(fb_score);fb_prevScore=fb_score;}}
void runFlappy(){
  fb_loadHi();
  tft.fillScreen(0x5DFF);
  tft.fillRoundRect(20,70,200,50,6,FB_PIPE_DARK);tft.fillRoundRect(22,72,196,46,5,ST77XX_YELLOW);
  tft.setTextColor(ST77XX_BLACK);tft.setTextSize(3);tft.setCursor(30,78);tft.print("FLAPPY BIRD");
  tft.setTextColor(ST77XX_WHITE);tft.setTextSize(1);tft.setCursor(30,140);tft.print("ANY BTN=START   MODE=menu");
  tft.setTextColor(ST77XX_YELLOW);tft.setCursor(70,160);tft.print("BEST: ");tft.print(fb_hi[0]);
  waitAllReleased();
  while(true){
    if(digitalRead(BTN_MODE)==LOW){waitAllReleased();currentState=STATE_MENU;return;}
    if(digitalRead(BTN_UP)==LOW||digitalRead(BTN_DOWN)==LOW||digitalRead(BTN_LEFT)==LOW||digitalRead(BTN_RIGHT)==LOW)break;
    delay(10);
  }
  waitAllReleased();
  // Start game
  fb_score=0;fb_prevScore=0xFFFF;fb_birdY=100;fb_birdVel=0;fb_birdFrame=0;
  for(int i=0;i<FB_MAX_PIPES;i++){fb_pipes[i].x=fb_pipes[i].prevX=240+30+i*(240/FB_MAX_PIPES+FB_PIPE_W);fb_pipes[i].topH=random(30,FB_GROUND_Y-FB_PIPE_GAP-30);fb_pipes[i].scored=false;}
  fb_state=FB_PLAYING;fb_lastFrame=fb_animTimer=millis();
  fb_bg();fb_hud(fb_score);
  bool lastBtn=false;
  while(fb_state==FB_PLAYING){
    if(digitalRead(BTN_MODE)==LOW){waitAllReleased();currentState=STATE_MENU;return;}
    uint32_t now=millis();
    if(now-fb_lastFrame>=FB_FRAME_MS){
      fb_lastFrame=now;
      bool btn=(digitalRead(BTN_UP)==LOW||digitalRead(BTN_DOWN)==LOW||digitalRead(BTN_LEFT)==LOW||digitalRead(BTN_RIGHT)==LOW);
      if(btn&&!lastBtn){fb_birdVel=FB_JUMP_VEL;fb_birdFrame=1;buzz(880,20);}
