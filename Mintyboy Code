      waitAllReleased();while(true){if(anyBtnPressed()){waitAllReleased();runMinesweeper();return;}delay(10);}
    }
    // Check win
    bool allSafe=true;
    for(int r=0;r<MS_ROWS;r++)for(int c=0;c<MS_COLS;c++)if(ms_board[r][c]!=9&&!ms_revealed[r][c])allSafe=false;
    if(allSafe){buzzWin();
      tft.fillRoundRect(30,100,180,40,6,0x0410);tft.drawRoundRect(30,100,180,40,6,ST77XX_GREEN);
      tft.setTextColor(ST77XX_GREEN);tft.setTextSize(2);tft.setCursor(68,110);tft.print("YOU WIN!");
      waitAllReleased();while(true){if(anyBtnPressed()){waitAllReleased();runMinesweeper();return;}delay(10);}
    }

    delay(10);
  }
}

