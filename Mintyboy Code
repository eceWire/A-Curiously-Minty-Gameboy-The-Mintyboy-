int  t_clearLines(){int cl=0;for(int y=T_ROWS-1;y>=0;y--){bool full=true;for(int x=0;x<T_COLS;x++)if(!tBoard[y][x]){full=false;break;}if(full){cl++;for(int ty=y;ty>0;ty--)for(int tx=0;tx<T_COLS;tx++)tBoard[ty][tx]=tBoard[ty-1][tx];for(int tx=0;tx<T_COLS;tx++)tBoard[0][tx]=0;y++;}}return cl;}
