void nasa_drawAPOD(){
  tft.fillScreen(COL_BG);nasa_drawTabBar();
  tft.setTextColor(ST77XX_YELLOW);tft.setTextSize(1);tft.setCursor(6,30);tft.print("Astronomy Picture of the Day");
  tft.drawFastHLine(0,40,240,COL_DIM);
  if(WiFi.status()!=WL_CONNECTED){tft.setTextColor(ST77XX_RED);tft.setCursor(6,52);tft.print("No WiFi — connect in Settings");tft.setTextColor(COL_DIM);tft.setCursor(6,220);tft.print("MODE=menu");return;}
  tft.setTextColor(ST77XX_CYAN);tft.setCursor(6,52);tft.print("Fetching APOD from NASA...");
  APODData apod=fetchAPOD();tft.fillScreen(COL_BG);nasa_drawTabBar();
  if(!apod.valid){tft.setTextColor(ST77XX_RED);tft.setCursor(6,52);tft.print("Fetch failed. Try again later.");tft.setTextColor(COL_DIM);tft.setCursor(6,220);tft.print("RIGHT=retry  MODE=menu");while(true){if(btnPressed(BTN_RIGHT)){nasa_drawAPOD();return;}if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}delay(10);}return;}
  // Classify
  String classify="Deep Space Object";
  String t=apod.title;t.toLowerCase();
  if(t.indexOf("nebula")>=0)classify="Nebula";
  else if(t.indexOf("galaxy")>=0)classify="Galaxy";
  else if(t.indexOf("black hole")>=0)classify="Black Hole";
  else if(t.indexOf("aurora")>=0)classify="Aurora";
  else if(t.indexOf("comet")>=0)classify="Comet";
  else if(t.indexOf("supernova")>=0)classify="Supernova";
  else if(t.indexOf("mars")>=0)classify="Planet: Mars";
  else if(t.indexOf("saturn")>=0)classify="Planet: Saturn";
  else if(t.indexOf("moon")>=0||t.indexOf("lunar")>=0)classify="Moon / Lunar";
  else if(t.indexOf("sun")>=0||t.indexOf("solar")>=0)classify="Sun / Solar";
  // Wrap explanation
  const int MAX_LINES=60;String lines[MAX_LINES];int totalLines=0;
  String ex=apod.explanation;
  while(ex.length()>0&&totalLines<MAX_LINES){int cut=min((int)ex.length(),36);if(cut<(int)ex.length()&&ex[cut]!=' '){int sp=ex.lastIndexOf(' ',cut);if(sp>0)cut=sp;}lines[totalLines++]=ex.substring(0,cut);ex=(cut<(int)ex.length())?ex.substring(cut+1):"";}
  const int BODY_Y=82,BODY_H=140,LINE_H=13,LINES_VIS=BODY_H/LINE_H,SCROLL_X=231,SCROLL_H=BODY_H;
  int scrollPos=0;
  auto drawHeader=[&](){tft.fillRect(0,24,240,58,COL_BG);tft.setTextColor(ST77XX_GREEN);tft.setTextSize(1);tft.setCursor(4,27);tft.print(apod.date);tft.fillRoundRect(130,24,106,13,3,0x000F);tft.setTextColor(ST77XX_CYAN);tft.setTextSize(1);tft.setCursor(134,27);tft.print(classify);tft.fillRoundRect(2,42,228,36,3,COL_CARD);tft.setTextColor(ST77XX_YELLOW);tft.setTextSize(1);tft.setCursor(5,47);tft.print(apod.title.substring(0,min((int)apod.title.length(),36)));if(apod.title.length()>36){tft.setCursor(5,60);tft.print(apod.title.substring(36,min((int)apod.title.length(),72)));}tft.drawFastHLine(0,80,240,COL_DIM);};
  auto drawScrollbar=[&](){tft.fillRect(SCROLL_X,BODY_Y,8,SCROLL_H,COL_CARD);tft.drawRect(SCROLL_X,BODY_Y,8,SCROLL_H,COL_DIM);if(totalLines<=LINES_VIS)return;int thumbH=max(8,SCROLL_H*LINES_VIS/totalLines);int thumbY=BODY_Y+(SCROLL_H-thumbH)*scrollPos/max(1,totalLines-LINES_VIS);tft.fillRect(SCROLL_X+1,thumbY,6,thumbH,ST77XX_CYAN);};
  auto drawBody=[&](){tft.fillRect(0,BODY_Y,SCROLL_X,BODY_H,COL_BG);for(int i=0;i<LINES_VIS;i++){int li=scrollPos+i;if(li>=totalLines)break;tft.setTextColor(COL_FG);tft.setTextSize(1);tft.setCursor(4,BODY_Y+i*LINE_H);tft.print(lines[li]);}drawScrollbar();};
  nasa_drawTabBar();drawHeader();drawBody();
  tft.fillRect(0,224,240,16,COL_BG);tft.setTextColor(COL_DIM);tft.setTextSize(1);tft.setCursor(4,228);tft.print("UP/DN=scroll  R=refresh  MODE=menu");
  while(true){
    if(btnPressed(BTN_UP)){if(scrollPos>0){scrollPos--;drawBody();}}
    if(btnPressed(BTN_DOWN)){if(scrollPos<totalLines-LINES_VIS){scrollPos++;drawBody();}}
    if(btnPressed(BTN_RIGHT)){nasa_drawAPOD();return;}
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}
    delay(10);
  }
}

void runNASA(){
  applyTheme();nasaTab=0;int planetIdx=0,moonIdx=0,artemisIdx=0;
  nasa_drawPlanet(planetIdx);
  while(true){
    if(btnPressed(BTN_UP)){nasaTab=(nasaTab+NASA_TABS-1)%NASA_TABS;switch(nasaTab){case 0:nasa_drawPlanet(planetIdx);break;case 1:nasa_drawMoon(moonIdx);break;case 2:nasa_drawArtemis(artemisIdx);break;case 3:nasa_drawAPOD();break;}}
    if(btnPressed(BTN_DOWN)){nasaTab=(nasaTab+1)%NASA_TABS;switch(nasaTab){case 0:nasa_drawPlanet(planetIdx);break;case 1:nasa_drawMoon(moonIdx);break;case 2:nasa_drawArtemis(artemisIdx);break;case 3:nasa_drawAPOD();break;}}
    if(btnPressed(BTN_LEFT)){switch(nasaTab){case 0:planetIdx=(planetIdx+NASA_NUM_PLANETS-1)%NASA_NUM_PLANETS;nasa_drawPlanet(planetIdx);break;case 1:moonIdx=(moonIdx+NASA_NUM_MOONS-1)%NASA_NUM_MOONS;nasa_drawMoon(moonIdx);break;case 2:artemisIdx=(artemisIdx+ARTEMIS_NUM_CARDS-1)%ARTEMIS_NUM_CARDS;nasa_drawArtemis(artemisIdx);break;}}
    if(btnPressed(BTN_RIGHT)){switch(nasaTab){case 0:planetIdx=(planetIdx+1)%NASA_NUM_PLANETS;nasa_drawPlanet(planetIdx);break;case 1:moonIdx=(moonIdx+1)%NASA_NUM_MOONS;nasa_drawMoon(moonIdx);break;case 2:artemisIdx=(artemisIdx+1)%ARTEMIS_NUM_CARDS;nasa_drawArtemis(artemisIdx);break;case 3:nasa_drawAPOD();break;}}
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}
    delay(10);
  }
}

