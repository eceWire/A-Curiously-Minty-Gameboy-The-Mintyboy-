      uint16_t nc[]={ST77XX_BLUE,ST77XX_GREEN,ST77XX_RED,0x001F,0x8000,ST77XX_CYAN,ST77XX_BLACK,0x8410};
      tft.setTextColor(nc[ms_board[cy][cx]-1]);tft.setTextSize(2);
      tft.setCursor(px+7,py+5);tft.print(ms_board[cy][cx]);
    }
  } else {
    tft.fillRect(px,py,MS_CELL-1,MS_CELL-1,cur?ST77XX_BLUE:COL_CARD);
    tft.drawRect(px,py,MS_CELL-1,MS_CELL-1,cur?ST77XX_WHITE:COL_DIM);
