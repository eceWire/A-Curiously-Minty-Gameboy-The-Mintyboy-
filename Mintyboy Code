    return;
  }

  tft.setTextColor(ST77XX_CYAN);tft.setTextSize(1);tft.setCursor(10,44);tft.print("Fetching headlines...");

  HTTPClient http;
  http.setTimeout(10000);
  http.begin("https://feeds.bbci.co.uk/news/world/rss.xml");
  http.addHeader("User-Agent", "ESP32");
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);  // ← ADD THIS
  int code = http.GET();

  if(code!=200){
    tft.fillRect(0,40,240,20,COL_BG);
    tft.setTextColor(ST77XX_RED);tft.setTextSize(1);tft.setCursor(10,60);tft.print("Fetch failed. Code: ");tft.print(code);
    tft.setTextColor(COL_DIM);tft.setCursor(10,120);tft.print("MODE=back");
    http.end();while(true){if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}delay(10);}return;
  }

  String xml=http.getString();http.end();

  // Parse <title> tags, skip first (feed title)
  const int MAX_HEADLINES=12;
  String headlines[MAX_HEADLINES];
  int count=0;int pos=0;bool first=true;
  while(count<MAX_HEADLINES){
    int ti=xml.indexOf("<title>",pos);if(ti<0)break;ti+=7;
    int te=xml.indexOf("</title>",ti);if(te<0)break;
    String title=xml.substring(ti,te);
    // Strip CDATA if present
    if(title.startsWith("<![CDATA[")){title=title.substring(9);title.replace("]]>","");}
    title.trim();
    if(!first&&title.length()>0&&!title.startsWith("BBC")){headlines[count++]=title;}
    first=false;pos=te+8;
  }

  tft.fillRect(0,40,240,200,COL_BG);

  if(count==0){
    tft.setTextColor(ST77XX_RED);tft.setTextSize(1);tft.setCursor(10,60);tft.print("No headlines found.");
    tft.setTextColor(COL_DIM);tft.setCursor(10,80);tft.print("MODE=back");
    while(true){if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}delay(10);}return;
  }

  // Display: 4 headlines per page, word-wrapped
  int topIdx=0;

  auto drawPage=[&](){
    tft.fillRect(0,36,240,204,COL_BG);
    tft.fillRect(0,36,240,12,COL_BG);
    tft.setTextColor(COL_DIM);tft.setTextSize(1);
    tft.setCursor(4,38);tft.print("U/D=scroll  MODE=back  BBC World News");
    tft.drawFastHLine(0,48,240,COL_DIM);
    for(int i=0;i<4&&(topIdx+i)<count;i++){
      int ny=52+i*46;bool sel=(i==0);
      tft.fillRoundRect(2,ny,236,42,4,sel?COL_CARD:COL_BG);
      tft.drawRoundRect(2,ny,236,42,4,sel?COL_ACCENT:COL_DIM);
      tft.setTextColor(sel?COL_FG:COL_DIM);tft.setTextSize(1);
      // Word-wrap to 36 chars x 2 lines
      String h=headlines[topIdx+i];
      tft.setCursor(6,ny+5);tft.print(h.substring(0,min((int)h.length(),36)));
      if(h.length()>36){tft.setCursor(6,ny+18);tft.print(h.substring(36,min((int)h.length(),72)));}
      tft.setTextColor(COL_DIM);tft.setCursor(6,ny+32);tft.print(String(topIdx+i+1)+"/"+String(count));
    }
  };
  drawPage();
  while(true){
    if(btnPressed(BTN_UP)){if(topIdx>0){topIdx--;drawPage();}}
    if(btnPressed(BTN_DOWN)){if(topIdx<count-1){topIdx++;drawPage();}}
    if(btnPressed(BTN_RIGHT)){
      // Refresh
      runNews();return;
    }
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}
    delay(10);
  }
}

