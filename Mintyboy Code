  }
  // Death screen
  tft.fillRoundRect(20,75,200,95,8,ST77XX_BLACK);tft.fillRoundRect(23,78,194,89,6,ST77XX_WHITE);
  tft.setTextColor(ST77XX_RED);tft.setTextSize(2);tft.setCursor(34,86);tft.print("GAME  OVER");
  tft.setTextColor(ST77XX_BLACK);tft.setTextSize(2);tft.setCursor(38,114);tft.print("SCORE:");tft.print(fb_score);
  tft.setTextSize(1);tft.setTextColor(0x8410);tft.setCursor(38,138);tft.print("BEST: ");tft.print(fb_hi[0]);
  tft.setTextColor(0x8410);tft.setTextSize(1);tft.setCursor(22,158);tft.print("ANY BTN=play again  MODE=menu");
  delay(1400);waitAllReleased();
  while(true){
    if(digitalRead(BTN_MODE)==LOW){waitAllReleased();currentState=STATE_MENU;return;}
    if(anyBtnPressed()){waitAllReleased();runFlappy();return;}
    delay(10);
  }
