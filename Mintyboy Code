      if(k[0]>='0'&&k[0]<='9'){
        if(newInput){display="";newInput=false;}
        if(display=="0")display="";
        display+=k;
      } else if(k[0]=='.'){
        if(display.indexOf('.')<0){if(newInput){display="0";newInput=false;}display+='.';}
      } else if(k[0]=='='){
        if(op&&!newInput){
          double cur=display.toDouble();
          double res=stored;
          if(op=='+')res=stored+cur;
          else if(op=='-')res=stored-cur;
          else if(op=='*')res=stored*cur;
          else if(op=='/'&&cur!=0)res=stored/cur;
          history=String(stored,4)+String(op)+String(cur,4)+"="+String(res,4);
