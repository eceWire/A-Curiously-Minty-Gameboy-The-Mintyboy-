#define BK_ROWS 5
#define BK_COLS 8
#define BK_BW   28
#define BK_BH   10
#define BK_GAP  2
#define BK_OX   2
#define BK_OY   20
#define BK_PAD_W  36
#define BK_PAD_H   6
#define BK_PAD_Y  220
#define BK_BALL_R   4

uint8_t bk_bricks[BK_ROWS][BK_COLS];
float bk_bx,bk_by,bk_vx,bk_vy;
int bk_padX,bk_lastPadX;
int bk_score,bk_lives;
bool bk_alive;
unsigned long bk_lastFrame;

const uint16_t bk_rowColors[BK_ROWS]={ST77XX_RED,ST77XX_ORANGE,ST77XX_YELLOW,ST77XX_GREEN,ST77XX_CYAN};

void bk_drawBrick(int r,int c,bool erase){
  int x=BK_OX+c*(BK_BW+BK_GAP),y=BK_OY+r*(BK_BH+BK_GAP);
  if(erase){tft.fillRect(x,y,BK_BW,BK_BH,COL_BG);return;}
  tft.fillRect(x,y,BK_BW,BK_BH,bk_rowColors[r]);
  tft.drawRect(x,y,BK_BW,BK_BH,ST77XX_WHITE);
}
void bk_drawHUD(){
  tft.fillRect(0,0,240,18,COL_BG);
  tft.setTextColor(COL_FG);tft.setTextSize(1);
  tft.setCursor(4,5);tft.print("Score:");tft.print(bk_score);
  tft.setCursor(150,5);tft.print("Lives:");tft.print(bk_lives);
}
void bk_init(){
  memset(bk_bricks,1,sizeof(bk_bricks));
  bk_padX=(SCREEN_WIDTH-BK_PAD_W)/2;bk_lastPadX=bk_padX;
  bk_bx=SCREEN_WIDTH/2;bk_by=BK_PAD_Y-BK_BALL_R-4;
  bk_vx=2.2f;bk_vy=-2.8f;
  bk_score=0;bk_lives=3;bk_alive=true;
}

void runBreakout(){
  applyTheme();bk_init();
  tft.fillScreen(COL_BG);bk_drawHUD();
  // Draw all bricks
  for(int r=0;r<BK_ROWS;r++) for(int c=0;c<BK_COLS;c++) bk_drawBrick(r,c,false);
  // Draw paddle and ball
  tft.fillRoundRect(bk_padX,BK_PAD_Y,BK_PAD_W,BK_PAD_H,3,ST77XX_CYAN);
  tft.fillCircle((int)bk_bx,(int)bk_by,BK_BALL_R,ST77XX_WHITE);
  tft.drawRect(0,18,240,210,COL_DIM); // border
  bk_lastFrame=millis();

  while(bk_alive){
    if(digitalRead(BTN_MODE)==LOW){waitAllReleased();currentState=STATE_MENU;return;}
    if(millis()-bk_lastFrame<16){delay(2);continue;}
    bk_lastFrame=millis();

    // Input
    int speed=4;
    if(digitalRead(BTN_LEFT)==LOW&&bk_padX>0)bk_padX-=speed;
    if(digitalRead(BTN_RIGHT)==LOW&&bk_padX<SCREEN_WIDTH-BK_PAD_W)bk_padX+=speed;

    // Erase old
    tft.fillRect(bk_lastPadX,BK_PAD_Y,BK_PAD_W,BK_PAD_H,COL_BG);
    tft.fillCircle((int)bk_bx,(int)bk_by,BK_BALL_R,COL_BG);

    bk_bx+=bk_vx;bk_by+=bk_vy;

    // Wall bounces
    if(bk_bx<=BK_BALL_R){bk_bx=BK_BALL_R;bk_vx=-bk_vx;}
    if(bk_bx>=SCREEN_WIDTH-BK_BALL_R){bk_bx=SCREEN_WIDTH-BK_BALL_R;bk_vx=-bk_vx;}
    if(bk_by<=19+BK_BALL_R){bk_by=19+BK_BALL_R;bk_vy=-bk_vy;}

    // Paddle bounce
    if(bk_by>=BK_PAD_Y-BK_BALL_R&&bk_vy>0&&(int)bk_bx>=bk_padX&&(int)bk_bx<=bk_padX+BK_PAD_W){
      bk_vy=-bk_vy;
      float rel=((float)((int)bk_bx-(bk_padX+BK_PAD_W/2)))/(BK_PAD_W/2);
      bk_vx=rel*3.5f;buzzClick();
    }

    // Brick collision
    int bix=(int)(bk_bx-BK_OX)/(BK_BW+BK_GAP);
    int biy=(int)(bk_by-BK_OY)/(BK_BH+BK_GAP);
    if(biy>=0&&biy<BK_ROWS&&bix>=0&&bix<BK_COLS&&bk_bricks[biy][bix]){
      bk_bricks[biy][bix]=0;bk_drawBrick(biy,bix,true);
      bk_score+=10*(BK_ROWS-biy);bk_vy=-bk_vy;bk_drawHUD();buzzPoints();
      // Check win
      bool anyLeft=false;
      for(int r=0;r<BK_ROWS;r++)for(int c=0;c<BK_COLS;c++)if(bk_bricks[r][c])anyLeft=true;
      if(!anyLeft){buzzWin();delay(800);bk_init();tft.fillScreen(COL_BG);bk_drawHUD();for(int r=0;r<BK_ROWS;r++)for(int c=0;c<BK_COLS;c++)bk_drawBrick(r,c,false);tft.drawRect(0,18,240,210,COL_DIM);}
    }

    // Ball out of bottom
    if(bk_by>SCREEN_HEIGHT){
      bk_lives--;buzzFail();bk_drawHUD();
      if(bk_lives<=0){bk_alive=false;break;}
      bk_bx=SCREEN_WIDTH/2;bk_by=BK_PAD_Y-BK_BALL_R-4;bk_vx=2.2f;bk_vy=-2.8f;
      tft.fillCircle((int)bk_bx,(int)bk_by,BK_BALL_R,ST77XX_WHITE);
    }

    // Redraw
    tft.fillRoundRect(bk_padX,BK_PAD_Y,BK_PAD_W,BK_PAD_H,3,ST77XX_CYAN);
    tft.fillCircle((int)bk_bx,(int)bk_by,BK_BALL_R,ST77XX_WHITE);
    bk_lastPadX=bk_padX;
  }

  buzzGameOver();
  tft.fillRoundRect(40,90,160,60,8,ST77XX_BLACK);tft.drawRoundRect(40,90,160,60,8,ST77XX_RED);
  tft.setTextColor(ST77XX_RED);tft.setTextSize(2);tft.setCursor(52,100);tft.print("GAME OVER");
  tft.setTextColor(ST77XX_WHITE);tft.setTextSize(1);tft.setCursor(52,122);tft.print("Score: ");tft.print(bk_score);
  tft.setCursor(42,136);tft.print("ANY BTN=retry  MODE=menu");
  waitAllReleased();
  while(true){
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}
    if(anyBtnPressed()){runBreakout();return;}
    delay(10);
  }
}

