// ======================================================
#define SN_COLS   20
#define SN_ROWS   18
#define SN_CELL   11
#define SN_OX     10
#define SN_OY     26
#define SN_MAXLEN 200

int8_t sn_bx[SN_MAXLEN], sn_by[SN_MAXLEN];
int sn_head, sn_len, sn_score;
int8_t sn_dx, sn_dy;
int8_t sn_fx, sn_fy;
bool sn_alive;
unsigned long sn_lastMove;
int sn_speed;

void sn_placeFood(){
  // Find an empty cell
  for(int tries=0;tries<200;tries++){
    int8_t fx=random(SN_COLS), fy=random(SN_ROWS);
    bool ok=true;
    for(int i=0;i<sn_len;i++){int idx=(sn_head-i+SN_MAXLEN)%SN_MAXLEN;if(sn_bx[idx]==fx&&sn_by[idx]==fy){ok=false;break;}}
    if(ok){sn_fx=fx;sn_fy=fy;return;}
  }
}

void sn_drawCell(int8_t x,int8_t y,uint16_t col){
  tft.fillRect(SN_OX+x*SN_CELL,SN_OY+y*SN_CELL,SN_CELL-1,SN_CELL-1,col);
}

void sn_drawHUD(){
  tft.fillRect(0,0,240,24,COL_BG);
  tft.setTextColor(ST77XX_GREEN);tft.setTextSize(2);tft.setCursor(4,4);tft.print("SNAKE");
  tft.setTextColor(ST77XX_WHITE);tft.setTextSize(1);tft.setCursor(120,4);tft.print("Score:");tft.print(sn_score);
  tft.setTextColor(COL_DIM);tft.setCursor(120,14);tft.print("MODE=menu");
}

void runSnake(){
  applyTheme();
  sn_len=4;sn_head=0;sn_score=0;sn_alive=true;sn_speed=250;
  sn_dx=1;sn_dy=0;
  for(int i=0;i<sn_len;i++){sn_bx[i]=sn_len-1-i;sn_by[i]=SN_ROWS/2;}
  sn_placeFood();sn_lastMove=millis();
  tft.fillScreen(COL_BG);
  // Draw border
  tft.drawRect(SN_OX-1,SN_OY-1,SN_COLS*SN_CELL+2,SN_ROWS*SN_CELL+2,COL_DIM);
  sn_drawHUD();
  // Draw initial snake
  for(int i=0;i<sn_len;i++){int idx=(sn_head-i+SN_MAXLEN)%SN_MAXLEN;sn_drawCell(sn_bx[idx],sn_by[idx],i==0?ST77XX_GREEN:0x03E0);}
  sn_drawCell(sn_fx,sn_fy,ST77XX_RED);

  int8_t ndx=sn_dx, ndy=sn_dy;

  while(sn_alive){
    // Input (don't allow 180° reverse)
    if(btnPressed(BTN_LEFT) &&sn_dx!=1) {ndx=-1;ndy=0;}
    if(btnPressed(BTN_RIGHT)&&sn_dx!=-1){ndx=1; ndy=0;}
    if(btnPressed(BTN_UP)   &&sn_dy!=1) {ndx=0; ndy=-1;}
    if(btnPressed(BTN_DOWN) &&sn_dy!=-1){ndx=0; ndy=1;}
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}

    if(millis()-sn_lastMove>=sn_speed){
      sn_lastMove=millis();
      sn_dx=ndx;sn_dy=ndy;

      int8_t nx=(int8_t)((sn_bx[sn_head]+sn_dx+SN_COLS)%SN_COLS);
      int8_t ny=(int8_t)((sn_by[sn_head]+sn_dy+SN_ROWS)%SN_ROWS);

      // Self-collision
      for(int i=0;i<sn_len-1;i++){int idx=(sn_head-i+SN_MAXLEN)%SN_MAXLEN;if(sn_bx[idx]==nx&&sn_by[idx]==ny){sn_alive=false;break;}}
      if(!sn_alive)break;

      // Erase tail
      int tail=(sn_head-sn_len+1+SN_MAXLEN)%SN_MAXLEN;
      bool ateFood=(nx==sn_fx&&ny==sn_fy);
      if(!ateFood){sn_drawCell(sn_bx[tail],sn_by[tail],COL_BG);} else {sn_score++;if(sn_len<SN_MAXLEN-1)sn_len++;sn_speed=max(80,sn_speed-4);sn_placeFood();sn_drawCell(sn_fx,sn_fy,ST77XX_RED);buzzPoints();}

      // Draw old head as body
      sn_drawCell(sn_bx[sn_head],sn_by[sn_head],0x03E0);

      // Advance head
      sn_head=(sn_head+1)%SN_MAXLEN;
      sn_bx[sn_head]=nx;sn_by[sn_head]=ny;
      sn_drawCell(nx,ny,ST77XX_GREEN);
      sn_drawHUD();
    }
    delay(10);
  }
  buzzGameOver();
  tft.fillRoundRect(40,90,160,60,8,ST77XX_BLACK);tft.drawRoundRect(40,90,160,60,8,ST77XX_RED);
  tft.setTextColor(ST77XX_RED);tft.setTextSize(2);tft.setCursor(52,100);tft.print("GAME OVER");
  tft.setTextColor(ST77XX_WHITE);tft.setTextSize(1);tft.setCursor(54,122);tft.print("Score: ");tft.print(sn_score);
  tft.setCursor(44,136);tft.print("ANY BTN=retry  MODE=menu");
  waitAllReleased();
  while(true){
    if(btnPressed(BTN_MODE)){currentState=STATE_MENU;return;}
    if(anyBtnPressed()){runSnake();return;}
    delay(10);
  }
}

