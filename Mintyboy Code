          val=res;op=0;newInput=true;buzzPoints();
        }
      } else {
        // Operator
        if(!newInput){stored=display.toDouble();}
        op=k[0];newInput=true;
      }
      drawCalc();
    }
    // DOWN = next row (already handled) + special bottom row via MODE hold
    if(digitalRead(BTN_MODE)==LOW){
      unsigned long t0=millis();
      while(digitalRead(BTN_MODE)==LOW){
        if(millis()-t0>1000){waitAllReleased();currentState=STATE_MENU;return;}
        delay(10);
      }
      // Short press = DEL
      if(display.length()>1)display.remove(display.length()-1);else display="0";
      buzzClick();drawCalc();
    }
    delay(10);
  }
}

